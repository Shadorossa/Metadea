---
import '../styles/core/global.css';
import '../styles/components/components.css';
import '../styles/components/navbar.css';
import '../styles/components/footer.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import type { Locale, Translations } from '../i18n/index';
import { useTranslations } from '../i18n/index';
import { STORAGE_KEYS } from '../lib/shared/storage-keys';
import ClientRouter from 'astro/components/ClientRouter.astro';

import '../styles/core/themes/nebula.css';
import '../styles/core/themes/cyberpunk.css';
import '../styles/core/themes/newspaper-dark.css';
import '../styles/core/themes/pipboy.css';
import '../styles/core/themes/glassmorphism.css';
import '../styles/core/themes/synthwave.css';
import '../styles/core/themes/steampunk.css';
import '../styles/core/themes/cyberneon.css';
import '../styles/core/themes/scifi.css';
import '../styles/core/themes/gothic.css';
import '../styles/core/themes/glitch.css';
import '../styles/core/themes/luxury.css';
import '../styles/core/themes/jungle.css';
import '../styles/core/themes/blueprint.css';

interface Props {
  title: string;
  lang: Locale;
  activePage?: 'home' | 'search' | 'local' | 'notifications' | 'profile' | 'tier';
}

const { title, lang, activePage } = Astro.props;
const t = useTranslations(lang);
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <ClientRouter />

    <!-- Apply theme before CSS loads to prevent flash -->
    <script is:inline define:vars={{ themeStorageKey: STORAGE_KEYS.appTheme }}>
      function applyTheme() {
        var t = localStorage.getItem(themeStorageKey) || 'nebula';
        document.documentElement.setAttribute('data-theme', t);
      }
      applyTheme();
      // Re-aplicar inmediatamente después de que Astro intercambie el HTML
      document.addEventListener('astro:after-swap', applyTheme);
      document.addEventListener('astro:page-load', applyTheme);
      window.__updateTheme = function(newTheme) {
        localStorage.setItem(themeStorageKey, newTheme);
        applyTheme();
      };
    </script>

  </head>
  <body data-page={activePage}>
    <div id="app-bg" aria-hidden="true" transition:persist></div>
    <Navbar activePage={activePage} i18n={t.nav} />
    <div id="page-content" transition:name="page-content">
      <slot />
    </div>
    <Footer lang={lang} />

    <!-- Auth modal -->
    <dialog id="auth-modal" class="auth-modal">
      <div class="auth-modal-box">

        <p class="modal-title">Crea tu perfil local</p>

        <form id="modal-login-form" style="display: flex; flex-direction: column; gap: 0.75rem; width: 100%;">
          <input 
            type="text" 
            id="modal-username-input" 
            class="input-dark" 
            placeholder="Nombre de usuario" 
            required 
            minlength="3" 
            maxlength="20"
          />
          <button type="submit" class="btn btn--primary" style="justify-content: center; width: 100%;">
            Comenzar
          </button>
        </form>

        <!-- Close -->
        <button class="auth-close" id="close-auth-modal" aria-label="Cerrar">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
    </dialog>

    <script>
      import { STORAGE_KEYS } from '../lib/shared/storage-keys';

      // Auth modal — runs on first load and after each View Transitions swap
      function initAuthModal() {
        const modal     = document.getElementById('auth-modal') as HTMLDialogElement | null;
        const closeBtn  = document.getElementById('close-auth-modal');
        const modalForm = document.getElementById('modal-login-form');
        const modalInput = document.getElementById('modal-username-input') as HTMLInputElement | null;

        closeBtn?.addEventListener('click', () => modal?.close());
        modal?.addEventListener('click', (e) => { if (e.target === modal) modal?.close(); });

        modalForm?.addEventListener('submit', async (e) => {
          e.preventDefault();
          const username = modalInput?.value.trim();
          if (username) {
            try {
              const { storeAuthToken } = await import(/* @vite-ignore */ '../lib/tauri');
              await storeAuthToken('offline_token', username);
              window.location.reload();
            } catch {
              console.error('Error storing token');
            }
          }
        });
      }
      
      let updaterChecked = false;
      let communityCatalogSynced = false;
      const COMMUNITY_CATALOG_SYNC_INTERVAL_MS = 24 * 60 * 60 * 1000; // 1/day

      async function syncCommunityCatalog() {
        if (typeof window === 'undefined' || !('__TAURI_IPC__' in window)) return;
        if (!navigator.onLine) return;
        try {
          const lastSync = localStorage.getItem(STORAGE_KEYS.communityCatalogLastSync);
          if (lastSync && Date.now() - parseInt(lastSync, 10) < COMMUNITY_CATALOG_SYNC_INTERVAL_MS) return;

          const { syncCommunityCatalog: sync } = await import(/* @vite-ignore */ '../lib/tauri');
          const imported = await sync();
          localStorage.setItem(STORAGE_KEYS.communityCatalogLastSync, String(Date.now()));
          if (imported > 0) {
            console.info(`[CommunityCatalog] Imported ${imported} new entries from the shared catalog.`);
          }
        } catch (error) {
          console.warn('[CommunityCatalog] Sync failed:', error);
        }
      }

      async function checkAppUpdates() {
        if (typeof window === 'undefined' || !('__TAURI_IPC__' in window)) return;
        if (!navigator.onLine) return;
        try {
          const { check } = await import('@tauri-apps/plugin-updater');
          const { relaunch } = await import('@tauri-apps/plugin-process');

          const update = await check();
          if (update && update.available) {
            const confirmUpdate = confirm(
              `¡Nueva versión ${update.version} disponible!\n\n¿Quieres descargarla e instalarla automáticamente ahora?`
            );
            if (confirmUpdate) {
              await update.downloadAndInstall();
              await relaunch();
            }
          }
        } catch (error) {
          console.warn("[Updater] No se pudo comprobar actualizaciones:", error);
        }
      }

      // Cache current path to restore session after full reloads/restarts
      function rememberCurrentPath() {
        const pathname = window.location.pathname;
        const search = window.location.search;
        const hash = window.location.hash;
        const fullPath = pathname + search + hash;

        // Don't save root or login pages
        if (pathname === '/' || pathname === '/login') {
          localStorage.removeItem(STORAGE_KEYS.lastVisitedPath);
          return;
        }

        localStorage.setItem(STORAGE_KEYS.lastVisitedPath, fullPath);
      }
      rememberCurrentPath();

      // Listeners and periodic check to keep the cached path updated
      window.addEventListener('beforeunload', rememberCurrentPath);
      setInterval(rememberCurrentPath, 1000);

      document.addEventListener('astro:page-load', async () => {
        try {
          const { initTauriDatabase } = await import('../lib/tauri');
          await initTauriDatabase();
        } catch (e) {
          console.error(e);
        }
        initAuthModal();
        setTimeout(rememberCurrentPath, 0);

        if (!updaterChecked) {
          updaterChecked = true;
          setTimeout(checkAppUpdates, 2000);
        }
        if (!communityCatalogSynced) {
          communityCatalogSynced = true;
          setTimeout(syncCommunityCatalog, 3000);
        }

        // Si navegamos fuera de la ficha, aseguramos resetear presencia de Discord
        if (!window.location.pathname.startsWith('/media')) {
          try {
            if (window.__TAURI__?.core?.invoke) {
              window.__TAURI__.core.invoke('reset_presence').catch(() => {});
            }
          } catch (e) {
            // Ignorar fuera de Tauri
          }
        }
      });
    </script>


  </body>
</html>
