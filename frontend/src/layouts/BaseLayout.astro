---
import '../styles/global.css';
import '../styles/components.css';
import '../styles/navbar.css';
import Navbar from '../components/Navbar.astro';
import type { Locale, Translations } from '../i18n/index';
import { useTranslations } from '../i18n/index';
import { ViewTransitions } from 'astro:transitions';

import nebulaUrl from '../styles/themes/nebula.css?url';
import auroraUrl from '../styles/themes/aurora.css?url';
import cosmosUrl from '../styles/themes/cosmos.css?url';
import emberUrl from '../styles/themes/ember.css?url';
import oceanUrl from '../styles/themes/ocean.css?url';
import sakuraUrl from '../styles/themes/sakura.css?url';
import cyberpunkUrl from '../styles/themes/cyberpunk.css?url';
import newspaperDarkUrl from '../styles/themes/newspaper-dark.css?url';

const themeUrls = {
  nebula: nebulaUrl,
  aurora: auroraUrl,
  cosmos: cosmosUrl,
  ember: emberUrl,
  ocean: oceanUrl,
  sakura: sakuraUrl,
  cyberpunk: cyberpunkUrl,
  'newspaper-dark': newspaperDarkUrl,
};

interface Props {
  title: string;
  lang: Locale;
  activePage?: 'home' | 'search' | 'local' | 'notifications' | 'profile';
}

const { title, lang, activePage } = Astro.props;
const t = useTranslations(lang);
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <ViewTransitions />
    <link id="theme-stylesheet" rel="stylesheet" href="" transition:persist />
    <!-- Apply theme before CSS loads to prevent flash -->
    <script is:inline define:vars={{ themeUrls }}>
      function applyTheme() {
        var t = localStorage.getItem('app_theme') || 'nebula';
        document.documentElement.setAttribute('data-theme', t);
        var link = document.getElementById('theme-stylesheet');
        if (link) link.setAttribute('href', themeUrls[t] || themeUrls['nebula']);
      }
      applyTheme();
      // Re-apply theme after each View Transitions navigation
      document.addEventListener('astro:after-swap', applyTheme);
      window.__updateTheme = function(newTheme) {
        localStorage.setItem('app_theme', newTheme);
        applyTheme();
      };
    </script>
  </head>
  <body data-page={activePage}>
    <div id="app-bg" aria-hidden="true" transition:persist></div>
    <Navbar activePage={activePage} i18n={t.nav} />
    <div id="page-content" transition:name="page-content">
      <slot />
    </div>

    <!-- Auth modal -->
    <dialog id="auth-modal" class="auth-modal">
      <div class="auth-modal-box">

        <p class="modal-title">Crea tu perfil local</p>

        <form id="modal-login-form" style="display: flex; flex-direction: column; gap: 0.75rem; width: 100%;">
          <input 
            type="text" 
            id="modal-username-input" 
            class="input-dark" 
            placeholder="Nombre de usuario" 
            required 
            minlength="3" 
            maxlength="20"
          />
          <button type="submit" class="btn btn--primary" style="justify-content: center; width: 100%;">
            Comenzar
          </button>
        </form>

        <!-- Close -->
        <button class="auth-close" id="close-auth-modal" aria-label="Cerrar">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
    </dialog>

    <script>
      // Auth modal — runs on first load and after each View Transitions swap
      function initAuthModal() {
        const modal     = document.getElementById('auth-modal') as HTMLDialogElement | null;
        const closeBtn  = document.getElementById('close-auth-modal');
        const modalForm = document.getElementById('modal-login-form');
        const modalInput = document.getElementById('modal-username-input') as HTMLInputElement | null;

        closeBtn?.addEventListener('click', () => modal?.close());
        modal?.addEventListener('click', (e) => { if (e.target === modal) modal?.close(); });

        modalForm?.addEventListener('submit', async (e) => {
          e.preventDefault();
          const username = modalInput?.value.trim();
          if (username) {
            try {
              const { storeAuthToken } = await import(/* @vite-ignore */ '../lib/tauri');
              await storeAuthToken('offline_token', username);
              window.location.reload();
            } catch {
              console.error('Error storing token');
            }
          }
        });
      }

      initAuthModal();
      document.addEventListener('astro:page-load', initAuthModal);
    </script>
  </body>
</html>
