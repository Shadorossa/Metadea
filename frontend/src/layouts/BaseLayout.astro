---
import '../styles/global.css';
import '../styles/components.css';
import '../styles/navbar.css';
import Navbar from '../components/Navbar.astro';
import type { Locale, Translations } from '../i18n/index';
import { useTranslations } from '../i18n/index';

interface Props {
  title: string;
  lang: Locale;
  activePage?: 'home' | 'search' | 'notifications' | 'profile';
}

const { title, lang, activePage } = Astro.props;
const t = useTranslations(lang);
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <Navbar activePage={activePage} i18n={t.nav} />
    <slot />

    <!-- Auth modal -->
    <dialog id="auth-modal" class="auth-modal">
      <div class="auth-modal-box">

        <p class="modal-title">Iniciar sesión</p>

        <a id="modal-google-btn" class="google-btn" href="#">
          <svg width="18" height="18" viewBox="0 0 48 48">
            <path fill="#FFC107" d="M43.6 20.1H42V20H24v8h11.3C33.7 32.7 29.2 36 24 36c-6.6 0-12-5.4-12-12s5.4-12 12-12c3.1 0 5.8 1.1 8 2.9l5.7-5.7C34.5 6.5 29.5 4 24 4 12.9 4 4 12.9 4 24s8.9 20 20 20 20-8.9 20-20c0-1.3-.1-2.7-.4-3.9z"/>
            <path fill="#FF3D00" d="M6.3 14.7l6.6 4.8C14.7 16.1 19 13 24 13c3.1 0 5.8 1.1 8 2.9l5.7-5.7C34.5 6.5 29.5 4 24 4 16.3 4 9.7 8.3 6.3 14.7z"/>
            <path fill="#4CAF50" d="M24 44c5.2 0 9.9-2 13.4-5.2l-6.2-5.2C29.2 35.3 26.7 36 24 36c-5.2 0-9.6-3.3-11.3-8H6.3C9.7 36.5 16.3 44 24 44z"/>
            <path fill="#1976D2" d="M43.6 20.1H42V20H24v8h11.3c-.8 2.3-2.3 4.2-4.3 5.6l6.2 5.2C41.4 35.5 44 30.2 44 24c0-1.3-.1-2.7-.4-3.9z"/>
          </svg>
          Continuar con Google
        </a>

        <!-- Close -->
        <button class="auth-close" id="close-auth-modal" aria-label="Cerrar">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
    </dialog>

    <script>
      import { getAuthToken, clearAuthToken } from '../lib/tauri';
      import { API_URL } from '../lib/config';

      const modal    = document.getElementById('auth-modal') as HTMLDialogElement;
      const closeBtn = document.getElementById('close-auth-modal');

      closeBtn?.addEventListener('click', () => modal?.close());
      modal?.addEventListener('click', (e) => { if (e.target === modal) modal.close(); });

      // Inicializar estado del dropdown según sesión
      (async () => {
        const session = await getAuthToken();
        const wrap = document.getElementById('nav-user-wrap');
        if (session?.token) {
          wrap?.classList.add('is-logged-in');
        }
      })();

      // Botón del perfil: si hay sesión → ir al perfil, si no → abrir modal
      document.getElementById('open-auth-modal')?.addEventListener('click', async () => {
        const session = await getAuthToken();
        if (session?.token) {
          window.location.href = '/profile';
        } else {
          modal?.showModal();
        }
      });

      // Cerrar sesión desde el dropdown
      document.getElementById('nav-signout-btn')?.addEventListener('click', async () => {
        await clearAuthToken();
        window.location.replace('/login');
      });

      // Botón Google dentro del modal
      document.getElementById('modal-google-btn')?.addEventListener('click', (e) => {
        e.preventDefault();
        window.location.href = `${API_URL}/api/auth/google`;
      });
    </script>
  </body>
</html>
