---
import '../styles/global.css';
import '../styles/components.css';
import '../styles/navbar.css';
import Navbar from '../components/Navbar.astro';
import type { Locale, Translations } from '../i18n/index';
import { useTranslations } from '../i18n/index';

interface Props {
  title: string;
  lang: Locale;
  activePage?: 'home' | 'search' | 'notifications';
}

const { title, lang, activePage } = Astro.props;
const t = useTranslations(lang);
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <Navbar activePage={activePage} i18n={t.nav} />
    <slot />

    <!-- Auth modal -->
    <dialog id="auth-modal" class="auth-modal">
      <div class="auth-modal-box">

        <!-- Tabs -->
        <div class="auth-tabs" role="tablist">
          <button class="auth-tab active" id="tab-login"    role="tab" data-tab="login">
            {t.auth.login}
          </button>
          <button class="auth-tab"        id="tab-register" role="tab" data-tab="register">
            {t.auth.register}
          </button>
        </div>

        <!-- Login panel -->
        <div class="auth-panel" id="panel-login">
          <p class="auth-coming-soon">{t.auth.coming_soon}</p>
          <form class="auth-form" onsubmit="return false">
            <input type="email"    class="input-dark" placeholder={t.auth.email}    disabled />
            <input type="password" class="input-dark" placeholder={t.auth.password} disabled />
            <button type="submit" class="auth-submit" disabled>{t.auth.login_submit}</button>
          </form>
          <p class="auth-switch">
            {t.auth.login_hint}
            <button class="auth-switch-btn" data-switch="register">{t.auth.register}</button>
          </p>
        </div>

        <!-- Register panel -->
        <div class="auth-panel hidden" id="panel-register">
          <p class="auth-coming-soon">{t.auth.coming_soon}</p>
          <form class="auth-form" onsubmit="return false">
            <input type="text"     class="input-dark" placeholder={t.auth.username} disabled />
            <input type="email"    class="input-dark" placeholder={t.auth.email}    disabled />
            <input type="password" class="input-dark" placeholder={t.auth.password} disabled />
            <button type="submit" class="auth-submit" disabled>{t.auth.register_submit}</button>
          </form>
          <p class="auth-switch">
            {t.auth.register_hint}
            <button class="auth-switch-btn" data-switch="login">{t.auth.login}</button>
          </p>
        </div>

        <!-- Close -->
        <button class="auth-close" id="close-auth-modal" aria-label="Cerrar">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
    </dialog>

    <script>
      const modal   = document.getElementById('auth-modal') as HTMLDialogElement;
      const closeBtn = document.getElementById('close-auth-modal');

      // Cerrar con el botón X
      closeBtn?.addEventListener('click', () => modal?.close());

      // Cerrar al hacer clic en el backdrop
      modal?.addEventListener('click', (e) => {
        if (e.target === modal) modal.close();
      });

      // Cambio de tab
      document.querySelectorAll<HTMLButtonElement>('.auth-tab, .auth-switch-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const target = btn.dataset.tab ?? btn.dataset.switch;
          if (!target) return;

          document.querySelectorAll('.auth-tab').forEach(t => t.classList.remove('active'));
          document.querySelectorAll('.auth-panel').forEach(p => p.classList.add('hidden'));

          document.getElementById(`tab-${target}`)?.classList.add('active');
          document.getElementById(`panel-${target}`)?.classList.remove('hidden');
        });
      });
    </script>
  </body>
</html>
