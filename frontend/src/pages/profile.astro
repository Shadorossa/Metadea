---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/pages/profile.css';
import '../styles/pages/media.css';
import { getLang, useTranslations } from '../i18n/index';
import { ProfileLibraryEditor } from '../components/profile/ProfileLibraryEditor';
import {
  ICON_PROFILE_OVERVIEW,
  ICON_PROFILE_LIBRARY,
  ICON_PROFILE_FAVORITES,
  ICON_PROFILE_STATS,
  ICON_PROFILE_REVIEWS,
  ICON_PROFILE_LISTS,
} from '../lib/shared/icon-strings';

const lang = getLang(Astro.url);
const t    = useTranslations(lang);
---

<BaseLayout title="Perfil — Metadea" lang={lang} activePage="profile">
  <main class="profile-page">

    <div class="profile-banner">
      <div class="profile-banner-content" id="banner-content">
        <script is:inline>
          (function() {
            var fontFiles = {
              inter: 'inter/Inter-VariableFont_opsz,wght.woff2',
              roboto: 'roboto/Roboto-VariableFont_wdth,wght.woff2',
              montserrat: 'montserrat/Montserrat-VariableFont_wght.woff2',
              raleway: 'raleway/Raleway-VariableFont_wght.woff2',
              syne: 'syne/Syne-VariableFont_wght.woff2',
              sourcesanspro: 'sourcesanspro/SourceSans3-VariableFont_wght.woff2',
              lora: 'lora/Lora-VariableFont_wght.woff2',
              playfairdisplay: 'playfairdisplay/PlayfairDisplay-VariableFont_wght.woff2',
              alegreya: 'alegreya/Alegreya-VariableFont_wght.woff2',
              fraunces: 'fraunces/Fraunces-VariableFont_SOFT,WONK,opsz,wght.woff2',
              librebaskerville: 'librebaskerville/LibreBaskerville-Bold.woff2',
              inconsolata: 'inconsolata/Inconsolata-VariableFont_wdth,wght.woff2'
            };
            var bannerCache = localStorage.getItem('profile_banner_cache');
            var avatarCache = localStorage.getItem('profile_avatar_cache');
            var fontCache = localStorage.getItem('profile_font_cache') || 'inter';
            var nameCache = localStorage.getItem('auth_username') || localStorage.getItem('profile_username_cache') || '';
            
            var fontFile = fontFiles[fontCache];
            if (fontFile) {
              var s = document.createElement('style');
              s.textContent = '@font-face { font-family: "profile-font"; src: url("/fonts/' + fontFile + '") format("woff2"); font-display: block; }';
              document.head.appendChild(s);
            }

            if (bannerCache) {
              var banner = document.querySelector('.profile-banner');
              if (banner) {
                banner.style.backgroundImage = "url('" + bannerCache + "')";
                banner.style.backgroundSize = 'cover';
                banner.style.backgroundPosition = 'center';
                banner.classList.add('has-custom-bg');
              }
            }
            if (nameCache) {
              var avatarHtml = avatarCache
                ? '<img class="profile-avatar" src="' + avatarCache + '" alt="' + nameCache + '" referrerpolicy="no-referrer">'
                : '<div class="profile-avatar-placeholder">' + (nameCache[0] || '?').toUpperCase() + '</div>';
              document.write(avatarHtml + '<h1 class="profile-username-large" style="font-family: \'profile-font\', sans-serif;">' + nameCache + '</h1>');
            }
          })();
        </script>
      </div>
    </div>

    <div class="profile-tabs-divider">
      <div class="profile-divider-line"></div>
    </div>

    <nav class="profile-tabs">
      <button class="profile-tab active" data-tab="overview" title="Perfil" set:html={ICON_PROFILE_OVERVIEW}></button>
      <button class="profile-tab" data-tab="library" title="Biblioteca" set:html={ICON_PROFILE_LIBRARY}></button>
      <button class="profile-tab" data-tab="favorites" title="Favoritos" set:html={ICON_PROFILE_FAVORITES}></button>
      <button class="profile-tab" data-tab="stats" title="Estadísticas" set:html={ICON_PROFILE_STATS}></button>
      <button class="profile-tab" data-tab="reviews" title="Reseñas" set:html={ICON_PROFILE_REVIEWS}></button>
      <button class="profile-tab" data-tab="lists" title="Listas" set:html={ICON_PROFILE_LISTS}></button>
      <script is:inline>
        (function() {
          var hash = window.location.hash.replace('#', '');
          var tabs = ['overview', 'library', 'favorites', 'stats', 'reviews', 'lists'];
          if (hash && tabs.indexOf(hash) !== -1) {
            var buttons = document.querySelectorAll('.profile-tab');
            buttons.forEach(function(btn) {
              btn.classList.toggle('active', btn.dataset.tab === hash);
            });
          }
        })();
      </script>
    </nav>

    <div id="profile-tab-content" class="profile-tab-content" style="opacity: 0; transition: opacity 0.12s ease;"></div>

    <ProfileLibraryEditor client:load i18n={t.media} />

  </main>
</BaseLayout>

<script>
  import { getAuthToken, getAllLibraryEntries, getAllCatalogEntries } from '../lib/tauri';
  import { decodeJwtPayload } from '../lib/profile/utils';
  import { renderOverview } from '../lib/profile/render-overview';
  import { renderLibrary } from '../lib/profile/render-library';
  import { renderFavorites } from '../lib/profile/render-favorites';
  import { renderStats } from '../lib/profile/render-stats';
  import { renderReviews } from '../lib/profile/reviews';
  import { renderLists }   from '../lib/profile/lists';
  import { getImage } from '../lib/storage/images';
  import { getFontFile } from '../lib/settings/fonts';
  import { STORAGE_KEYS } from '../lib/shared/storage-keys';

  (document.getElementById('auth-modal') as HTMLDialogElement | null)?.close();

  const TABS = ['overview', 'library', 'favorites', 'stats', 'reviews', 'lists'] as const;
  type Tab = typeof TABS[number];

  function getTabFromHash(): Tab {
    const h = location.hash.replace('#', '') as Tab;
    return TABS.includes(h) ? h : 'overview';
  }

  let cachedItems: Awaited<ReturnType<typeof getAllLibraryEntries>> = [];
  let cachedCatalog: Awaited<ReturnType<typeof getAllCatalogEntries>> = [];
  let activeTab: Tab = getTabFromHash();

  async function switchTab(tab: Tab) {
    activeTab = tab;
    history.replaceState(null, '', tab === 'overview' ? '/profile' : `/profile#${tab}`);

    document.querySelectorAll<HTMLButtonElement>('.profile-tab').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.tab === tab);
    });

    const content = document.getElementById('profile-tab-content');
    if (!content) return;

    content.classList.add('switching');
    await new Promise(r => setTimeout(r, 120));

    if      (tab === 'overview')   await renderOverview(content, cachedItems);
    else if (tab === 'library')   await renderLibrary(content);
    else if (tab === 'favorites') await renderFavorites(content);
    else if (tab === 'stats')     await renderStats(content);
    else if (tab === 'reviews')   await renderReviews(content);
    else if (tab === 'lists')     await renderLists(content);

    content.classList.remove('switching');
    content.style.opacity = '1';
  }

  async function init() {
    // Bail out if profile tab content is not present
    if (!document.getElementById('profile-tab-content')) return;

    // Immediately cache profile path to make reloads solid
    localStorage.setItem(STORAGE_KEYS.lastVisitedPath, window.location.pathname + window.location.search + window.location.hash);

    const session = await getAuthToken().catch(() => null);
    if (!session?.token) { window.location.replace('/login'); return; }

    const payload  = decodeJwtPayload(session.token);
    const avatar   = payload.avatar as string | null;
    const username = session.username;

    // Custom banner image
    const bannerEl = document.querySelector('.profile-banner') as HTMLElement | null;
    const customBanner = await getImage(STORAGE_KEYS.profileBannerCustom);
    if (bannerEl && customBanner) {
      bannerEl.style.backgroundImage = `url('${customBanner}')`;
      bannerEl.style.backgroundSize = 'cover';
      bannerEl.style.backgroundPosition = 'center';
      bannerEl.classList.add('has-custom-bg');
      localStorage.setItem('profile_banner_cache', customBanner);
    } else {
      localStorage.removeItem('profile_banner_cache');
    }

    // Custom avatar takes priority over Google avatar
    const customAvatar = await getImage(STORAGE_KEYS.profileAvatarCustom);
    const avatarSrc = customAvatar || avatar;
    if (avatarSrc) {
      localStorage.setItem('profile_avatar_cache', avatarSrc);
    } else {
      localStorage.removeItem('profile_avatar_cache');
    }
    if (username) {
      localStorage.setItem('profile_username_cache', username);
    }

    const bannerContent = document.getElementById('banner-content');
    if (bannerContent) {
      const avatarHtml = avatarSrc
        ? `<img class="profile-avatar" src="${avatarSrc}" alt="${username}" referrerpolicy="no-referrer">`
        : `<div class="profile-avatar-placeholder">${(username[0] ?? '?').toUpperCase()}</div>`;

      const { getUserInfo } = await import('../lib/tauri');
      const userInfo = await getUserInfo();
      const fontId = (userInfo.font as string | undefined) ?? 'inter';
      localStorage.setItem('profile_font_cache', fontId);
      const fontSrc = getFontFile(fontId);
      if (fontSrc) {
        const s = document.createElement('style');
        s.textContent = `@font-face { font-family: "profile-font"; src: url("/fonts/${fontSrc}") format("woff2"); font-display: swap; }`;
        document.head.appendChild(s);
      }

      const newHTML = `${avatarHtml}<h1 class="profile-username-large" style="font-family: 'profile-font', sans-serif;">${username}</h1>`;
      const norm = (h) => h.replace(/\s+/g, ' ').replace(/'/g, '"').trim();
      if (norm(bannerContent.innerHTML) !== norm(newHTML)) {
        bannerContent.innerHTML = newHTML;
      }
    }

    document.querySelectorAll<HTMLButtonElement>('.profile-tab').forEach(btn => {
      btn.addEventListener('click', () => switchTab(btn.dataset.tab as Tab));
    });

    [cachedItems, cachedCatalog] = await Promise.all([
      getAllLibraryEntries().catch(() => []),
      getAllCatalogEntries().catch(() => [])
    ]);
    await switchTab(activeTab);

    // Delegate clicks: card body → open editor in modal, cover <a> handles its own navigation
    document.getElementById('profile-tab-content')?.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('.library-card-thumb')) return;

      const card = (e.target as HTMLElement).closest<HTMLElement>('.library-card[data-id]');
      if (!card) return;

      const extId = card.dataset.id;
      const libraryEntry = cachedItems.find(item => item.external_id === extId);
      const catalogEntry = cachedCatalog.find(item => item.external_id === extId);

      if (extId && libraryEntry && catalogEntry) {
        window.dispatchEvent(new CustomEvent('open-profile-editor', {
          detail: {
            externalId: extId,
            libraryEntry,
            catalogEntry
          }
        }));
      }
    });

    window.addEventListener('refresh-profile-library', async () => {
      cachedItems = await getAllLibraryEntries().catch(() => []);
      const content = document.getElementById('profile-tab-content');
      if (content && activeTab === 'library') {
        await renderLibrary(content);
      }
    });
  }

  document.addEventListener('astro:page-load', init);
</script>
