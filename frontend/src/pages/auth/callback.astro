---
import { getLang, useTranslations } from '../../i18n/index';
import '../../styles/core/global.css';
import '../../styles/pages/login.css';

const lang = getLang(Astro.url);
const t    = useTranslations(lang);
---
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <title>{t.auth.authenticating}</title>
  </head>
  <body class="callback-body">
    <p id="status" data-error-template={t.auth.callback_error} data-save-error-template={t.auth.save_session_error}>{t.auth.signing_in}</p>

    <script>
      import { storeAuthToken, initTauriDatabase } from '../../lib/tauri';
      import { API_URL } from '../../lib/config';

      // Standalone page (no BaseLayout) — every invoke() call (see
      // lib/tauri/core.ts) awaits a promise that only resolves once this
      // runs, so without it storeAuthToken's invoke('store_auth_token')
      // below would hang forever with no error and no visible feedback.
      initTauriDatabase().catch(e => console.error('Failed to init Tauri database:', e));

      const params = new URLSearchParams(window.location.search);
      const code   = params.get('code');
      const error  = params.get('error');

      const status = document.getElementById('status')!;

      // The redirect only ever carries a one-time exchange code, never the
      // session JWT itself (see backend/src/routes/auth.ts's
      // exchangeAuthCode) — the actual token only appears in this POST's
      // JSON response, never in a URL that could end up in browser history,
      // server logs, or a Referer header.
      async function redeemCode() {
        const res = await fetch(`${API_URL}/api/auth/exchange`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ code }),
        });
        if (!res.ok) throw new Error((await res.json().catch(() => null))?.error || 'Exchange failed');
        return res.json();
      }

      const errorTemplate = status.dataset.errorTemplate || 'Error: {message}';
      const saveErrorTemplate = status.dataset.saveErrorTemplate || 'Error saving session: {message}';

      if (error) {
        status.textContent = errorTemplate.replace('{message}', decodeURIComponent(error));
        setTimeout(() => { window.location.replace('/login'); }, 2000);
      } else if (code) {
        redeemCode()
          .then(({ token, username }) => storeAuthToken(token, username ?? ''))
          .then(() => { window.location.replace('/home'); })
          .catch((err) => {
            status.textContent = saveErrorTemplate.replace('{message}', err?.message ?? String(err));
            console.error('[callback] auth exchange failed:', err);
            setTimeout(() => { window.location.replace('/login'); }, 3000);
          });
      } else {
        window.location.replace('/login');
      }
    </script>
  </body>
</html>
