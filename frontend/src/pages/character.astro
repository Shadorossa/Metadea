---
import BaseLayout from '../layouts/BaseLayout.astro';
import { CharacterPrEditorModal } from '../components/character/CharacterPrEditorModal';
import '../styles/pages/character.css';
import '../styles/pages/media.css';
import { getLang, useTranslations } from '../i18n/index';

const lang = getLang(Astro.url);
const translations = useTranslations(lang);
---

<BaseLayout title="Detalle de Personaje — Metadea" lang={lang} activePage="search">
  <div class="media-page">

    <!-- Estado de Carga -->
    <div id="character-loading" class="media-loading">
      <p>Cargando información del personaje...</p>
    </div>

    <!-- Estado de Error -->
    <div id="character-error" class="media-error" style="display: none;">
      <p style="font-weight: 700; margin-bottom: 0.5rem;">Error al cargar personaje</p>
      <p id="character-error-text" style="font-size: 0.85rem; opacity: 0.8;"></p>
    </div>

    <!-- Contenido del Personaje -->
    <div id="character-content" style="display: none;" data-char-key="">
      
      <!-- Hero principal -->
      <div class="character-hero-body">
        <div class="character-hero-left-col">
          <div class="character-avatar-frame">
            <div class="character-avatar-wrap" id="char-avatar-container"></div>
          </div>
          <div class="character-action-row" id="char-action-row">
            <button class="char-action-btn" id="char-fav-btn" data-action="favorite" title="Favorito">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
              </svg>
              <span>Favorito</span>
            </button>
            <button class="char-action-btn" id="char-like-btn" data-action="like" data-reaction="like" title="Me gusta">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M7 10v12"/><path d="M15 5.88 14 10h5.83a2 2 0 0 1 1.92 2.56l-2.33 8A2 2 0 0 1 17.5 22H4a2 2 0 0 1-2-2v-8a2 2 0 0 1 2-2h2.76a2 2 0 0 0 1.79-1.11L12 2a3.13 3.13 0 0 1 3 3.88Z"/>
              </svg>
              <span>Me gusta</span>
            </button>
            <button class="char-action-btn" id="char-interested-btn" data-action="interested" data-reaction="interested" title="Interesa">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/>
              </svg>
              <span>Interesa</span>
            </button>
            <button class="char-action-btn" id="char-dislike-btn" data-action="dislike" data-reaction="dislike" title="No me gusta">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 14V2"/><path d="M9 18.12 10 14H4.17a2 2 0 0 1-1.92-2.56l2.33-8A2 2 0 0 1 6.5 2H20a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2h-2.76a2 2 0 0 0-1.79 1.11L14 22a3.13 3.13 0 0 1-3-3.88Z"/>
              </svg>
              <span>No me gusta</span>
            </button>
          </div>
        </div>

        <div class="character-hero-right-col">
          <div class="character-name-row">
            <h1 class="media-title-main" id="char-name-full"></h1>
            <button type="button" class="btn btn--sm btn--secondary" id="char-edit-btn-header" onclick="handleEditClick()" title="Editar datos del personaje">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"></path></svg>
              Editar
            </button>
          </div>
          <p class="media-title-native" id="char-name-native" style="display: none; margin-top: 0.25rem;"></p>
          
          <div class="character-alt-names-wrap" id="char-alt-names-wrap" style="display: none;">
            <div class="character-alt-names" id="char-alt-names"></div>
          </div>
        </div>
      </div>

      <!-- Body: 3 Columnas (Biografía, Apariciones en Obras, Datos) -->
      <div class="media-body" style="padding-top: 2rem;">
        <!-- Columna 1: Biografía -->
        <div class="media-col-synopsis" id="char-bio-section" style="display: none;">
          <div class="media-section-header-row">
            <p class="section-label">Biografía</p>
            <div class="media-section-header-line"></div>
          </div>
          <div class="media-description-text" id="char-description"></div>
        </div>

        <!-- Columna 2: Apariciones en Obras -->
        <div class="media-col-related" id="char-appearances-section" style="display: none;">
          <div class="media-section-header-row">
            <p class="section-label">Apariciones en Obras</p>
            <div class="media-section-header-line"></div>
          </div>
          <div class="media-relations-grid" id="char-appearances-grid"></div>
          
          <!-- Paginación -->
          <div id="appearances-pagination" style="display: none; justify-content: center; align-items: center; gap: 1.5rem; margin-top: 2rem; border-top: 1px solid var(--border-color); padding-top: 1.5rem;">
            <button class="btn btn--sm btn--secondary" id="btn-prev-appearances" style="min-width: 100px;">Anterior</button>
            <span id="txt-appearances-page" style="font-size: 0.8rem; color: var(--text-muted); font-weight: 600;">Página 1 de 1</span>
            <button class="btn btn--sm btn--secondary" id="btn-next-appearances" style="min-width: 100px;">Siguiente</button>
          </div>
        </div>

        <!-- Columna 3: Datos -->
        <div class="media-col-stats" id="char-stats-card" style="display: none;">
          <div class="media-section-header-row">
            <p class="section-label">Datos</p>
            <div class="media-section-header-line"></div>
            <div id="char-api-link-wrap"></div>
          </div>
          <div class="media-stats-list" id="char-stats-list"></div>

          <!-- Actores de Voz por Idioma (debajo de datos) -->
          <div class="char-seiyu-section" id="char-seiyu-section" style="display: none; margin-top: 1rem;">
            <div class="media-authors-box" style="margin-bottom: 0.75rem;">
              <div class="media-authors-list" id="char-seiyu-list"></div>
            </div>
            <div class="char-seiyu-lang-tabs" id="char-seiyu-lang-tabs"></div>
          </div>
        </div>
      </div>

    </div>

  </div>
</BaseLayout>

<CharacterPrEditorModal client:load />

<script>
  window.handleEditClick = function() {
    const charKeyEl = document.querySelector('[data-char-key]');
    if (!charKeyEl) return;
    const charKey = charKeyEl.getAttribute('data-char-key');
    if (!charKey) return;
    if (window.openCharacterEditor) {
      window.openCharacterEditor(charKey);
    }
  };

  import { fetchAniListCharacterDetail, type AniListCharacterDetail } from '../lib/search/providers/anilist';
  import { parseCharacterBiography } from '../lib/character/biography-parser';
  import { compareByReleaseDateDesc, mapExternalFormatToType } from '../lib/media/mapper-utils';
  import { needsResync } from '../lib/media/media-status';
  import { sanitizeHtml, escapeHtml, safeUrl } from '../lib/shared/sanitize-html';
  import {
    readUserFavorites,
    syncFavorites,
    saveCharacter,
    getCharacter,
    setCharacterReaction,
    getCharacterAppearances,
    saveCharacterAppearances,
    getCharacterActors,
    getCatalogEntry,
    getSyncState,
    markSynced,
    markSyncFailed,
    type CharacterEntry,
  } from '../lib/tauri';

  // Reconstructs an AniListCharacterDetail-shaped object purely from what's
  // cached locally, so every downstream render (stats, name/native/image,
  // aliases) works unchanged whether `character` came from a live AniList
  // fetch or was skipped because sync_state says it isn't due for a resync
  // yet. media.edges stays empty — appearances/voice-actors already have
  // their own local-first merge (character_appearances / character_actors)
  // that tolerates an empty live edge list fine.
  function localCharacterToDetail(id: number, lc: CharacterEntry): AniListCharacterDetail {
    return {
      id,
      name: {
        full: lc.name,
        native: lc.name_native ?? null,
        alternative: lc.aliases_csv ? lc.aliases_csv.split(',').map(s => s.trim()).filter(Boolean) : [],
        alternativeSpoiler: [],
      },
      image: { large: lc.image_url ?? null },
      description: lc.biography ?? null,
      gender: lc.gender ?? null,
      dateOfBirth: { year: lc.dob_year ?? null, month: lc.dob_month ?? null, day: lc.dob_day ?? null },
      age: lc.age ?? null,
      bloodType: lc.blood_type ?? null,
      media: { edges: [] },
    };
  }

  async function loadCharacterData() {
    const lang = window.location.pathname.startsWith('/en') ? 'en' : 'es';
    window.ROLE_LABELS = {
      MAIN: lang === 'en' ? 'Main' : 'Principal',
      SUPPORTING: lang === 'en' ? 'Supporting' : 'Secundario',
      BACKGROUND: 'Background',
    };

    const loadingEl = document.getElementById('character-loading');
    const errorEl = document.getElementById('character-error');
    const errorTextEl = document.getElementById('character-error-text');
    const contentEl = document.getElementById('character-content');
    if (!loadingEl || !errorEl || !errorTextEl || !contentEl) return;

    const urlParams = new URLSearchParams(window.location.search);
    const idParam = urlParams.get('id') ?? '';

    if (idParam.startsWith('comicvine:')) {
      loadingEl.style.display = 'none';
      errorTextEl.textContent = 'La ficha de personajes de Comic Vine aún no está disponible.';
      errorEl.style.display = 'block';
      return;
    }

    const cleanIdParam = idParam.replace(/\D/g, '');
    const characterId = parseInt(cleanIdParam, 10);
    // Canonical local-DB key for this character — matches the `character:<id>`
    // format every other write path already uses (anilist-mapper.ts's cast-list
    // import, search/providers/anilist.ts's character search). `characterId`
    // itself stays bare where it's an AniList API id, not a DB key (the
    // fetchAniListCharacterDetail call and the anilist.co siteUrl fallback below).
    const characterExternalId = `character:${characterId}`;

    if (isNaN(characterId)) {
      loadingEl.style.display = 'none';
      errorTextEl.textContent = 'ID de personaje no válido o no especificado';
      errorEl.style.display = 'block';
      return;
    }

    try {
      // Fetched once, reused below for every field the PR editor lets you
      // correct (name/native/image/biography/aliases) — a local edit always
      // wins over AniList's live copy, same "sticky local field" rule
      // mediaService.ts's applyStickyLocalFields uses for media pages.
      // Without this the character page always showed AniList's raw data
      // and any manual correction made in the editor never appeared here.
      const localChar = await getCharacter(characterExternalId).catch(() => null);

      // sync_state gates the live AniList call the same way needsResync()
      // already gates media_catalog resyncs — this page used to hit AniList
      // unconditionally on every single visit regardless of how fresh the
      // local copy already was.
      const syncState = await getSyncState(characterExternalId).catch(() => null);
      const dueForResync = needsResync(syncState ? {
        last_synced_at: syncState.last_synced_at,
        sync_failed_count: syncState.sync_failed_count,
      } : null);

      let character: AniListCharacterDetail;
      if (dueForResync || !localChar) {
        const live = await fetchAniListCharacterDetail(characterId);
        if (live) {
          character = live;
          markSynced(characterExternalId).catch(() => {});
        } else if (localChar) {
          // Live fetch failed (rate limit, network hiccup, ...) but a local
          // copy already exists — degrade to that instead of a hard error,
          // same backoff-on-failure behavior mediaService.ts uses for media.
          markSyncFailed(characterExternalId, 'Live fetch returned no data').catch(() => {});
          character = localCharacterToDetail(characterId, localChar);
        } else {
          loadingEl.style.display = 'none';
          errorTextEl.textContent = 'No se encontró el personaje especificado en AniList.';
          errorEl.style.display = 'block';
          return;
        }
      } else {
        // Not due for a resync and a local copy already exists — skip the
        // AniList call entirely instead of re-fetching on every page visit.
        character = localCharacterToDetail(characterId, localChar);
      }

      const stickyName = localChar?.name || character.name.full;
      const stickyNameNative = localChar?.name_native || character.name.native || null;
      // A locally-stored image only gets replaced by the fresh AniList fetch
      // when it's itself an old AniList "medium" thumbnail (e.g. seeded by a
      // media page's character grid — save_characters_skeleton's INSERT OR
      // IGNORE means it never upgrades itself otherwise) — never for a
      // custom crop (data: URL) or any other deliberately-set image, which
      // stay sticky like every other manually-edited field.
      const localImageIsAniListMedium = !!localChar?.image_url
        && localChar.image_url.includes('anilist.co')
        && localChar.image_url.includes('/medium/');
      const stickyImage = (localChar?.image_url && !localImageIsAniListMedium)
        ? localChar.image_url
        : (character.image?.large || localChar?.image_url || null);
      const stickyBiography = localChar?.biography || character.description;

      // Nombre principal y nativo
      document.getElementById('char-name-full')!.textContent = stickyName;
      const nativeEl = document.getElementById('char-name-native')!;
      if (stickyNameNative) {
        nativeEl.textContent = stickyNameNative;
        nativeEl.style.display = 'block';
      } else {
        nativeEl.style.display = 'none';
      }

      // Imagen / Avatar
      const avatarContainer = document.getElementById('char-avatar-container')!;
      if (stickyImage) {
        avatarContainer.innerHTML = `<img src="${safeUrl(stickyImage)}" alt="${escapeHtml(stickyName)}" class="character-avatar-img" />`;
      } else {
        avatarContainer.innerHTML = `<div class="character-avatar-placeholder">Sin imagen</div>`;
      }

      // Parseo de biografía para extraer características
      const { characteristics: parsedStats, cleanBiography } = parseCharacterBiography(stickyBiography);
      const cleanDescription = cleanBiography.replace(/~!([\s\S]*?)!~/g, '<span class="spoiler">$1</span>');

      // ── EXTRAER Y CONSOLIDAR ABSOLUTAMENTE TODOS LOS ALIASES ──
      const aliasMap = new Map<string, { text: string; spoiler: boolean }>();
      const mainNameLower = stickyName.toLowerCase().trim();
      const nativeNameLower = (stickyNameNative || '').toLowerCase().trim();

      function addAlias(rawText: string, spoiler: boolean = false) {
        if (!rawText) return;
        const clean = rawText.replace(/<[^>]*>/g, '').trim();
        if (!clean) return;
        const parts = clean.split(/[,;\n]/).map(s => s.trim()).filter(Boolean);
        for (const p of parts) {
          const key = p.toLowerCase().trim();
          if (key && key !== mainNameLower && key !== nativeNameLower && key.length > 1 && !aliasMap.has(key)) {
            aliasMap.set(key, { text: p, spoiler });
          }
        }
      }

      // 1. AniList alternative names
      for (const alt of character.name?.alternative ?? []) addAlias(alt, false);
      for (const alt of character.name?.alternativeSpoiler ?? []) addAlias(alt, true);

      // 2. Local DB saved aliases
      if (localChar?.aliases_csv) {
        for (const alt of localChar.aliases_csv.split(',')) addAlias(alt, false);
      }

      // 3. Biografía parsed bold labels ("Aliases", "AKA", "Nicknames", etc.)
      for (const stat of parsedStats) {
        const lbl = stat.label.toLowerCase();
        if (
          lbl.includes('alias') ||
          lbl.includes('nombre') ||
          lbl.includes('name') ||
          lbl.includes('aka') ||
          lbl.includes('nickname') ||
          lbl.includes('title')
        ) {
          addAlias(stat.value, false);
        }
      }

      // 4. Biografía text patterns ("also known as X", "known as X")
      // Deliberately does NOT also grab arbitrary "(...)" text from the bio —
      // that used to add anything in parentheses as an "alias", but a
      // biography's parentheticals are usually team names, arcs, or asides
      // ("the Aliea Gakuen arc", "(Coach)"), not alternate names, and there's
      // no reliable way to tell those apart from a real one this way.
      const rawDesc = stickyBiography || '';
      const akaRegex = /(?:also\s+known\s+as|known\s+as|referred\s+to\s+as|also\s+called|alias(?:es)?)\s+([^,.\n(<]+)/gi;
      let match;
      while ((match = akaRegex.exec(rawDesc)) !== null) {
        if (match[1]) addAlias(match[1], false);
      }

      const allAliases = Array.from(aliasMap.values());
      const altNamesWrap = document.getElementById('char-alt-names-wrap')!;
      const altNamesContainer = document.getElementById('char-alt-names')!;

      if (allAliases.length > 0) {
        altNamesContainer.innerHTML = allAliases
          .map(({ text, spoiler }) => spoiler
            ? `<span class="character-alt-name-tag"><span class="spoiler">${escapeHtml(text)}</span></span>`
            : `<span class="character-alt-name-tag">${escapeHtml(text)}</span>`)
          .join('');
        altNamesWrap.style.display = 'block';
      } else {
        altNamesWrap.style.display = 'none';
      }

      // ── ENLACE A LA API DE ORIGEN (ANILIST) ──
      const apiLinkWrap = document.getElementById('char-api-link-wrap');
      const siteUrl = character.siteUrl || `https://anilist.co/character/${characterId}`;
      if (apiLinkWrap) {
        apiLinkWrap.innerHTML = `
          <a href="${safeUrl(siteUrl)}" target="_blank" rel="noopener noreferrer" class="media-store-link" title="AniList">
            <img src="/API/Anilist_logo.png" alt="AniList" class="media-store-icon" />
          </a>
        `;
      }

      // ── EXTRAER Y AGRUPAR ACTORES DE VOZ POR IDIOMA ──
      const LANG_MAP: Record<string, { code: string; label: string }> = {
        'japanese': { code: 'JP', label: 'Japonés' },
        'spanish': { code: 'ES', label: 'Español' },
        'english': { code: 'EN', label: 'Inglés' },
        'italian': { code: 'IT', label: 'Italiano' },
        'french': { code: 'FR', label: 'Francés' },
        'german': { code: 'DE', label: 'Alemán' },
        'portuguese': { code: 'PT', label: 'Portugués' },
        'korean': { code: 'KR', label: 'Coreano' },
        'chinese': { code: 'ZH', label: 'Chino' },
        'mandarin': { code: 'ZH', label: 'Chino' },
      };

      // Local DB actors overlay the live AniList cast list the same way the
      // PR editor merges them (see CharacterPrEditorModal.tsx's vaMap) — a
      // locally-added actor (no AniList counterpart at all) or a locally
      // edited role/language must show here too, not just in the editor.
      // Keyed by external_id ("person:a{id}" for a real AniList staff pick,
      // "va:{name}" for a manually-typed legacy entry) instead of AniList's
      // own numeric id, since a local-only actor has no such id.
      interface MergedVoiceActor {
        externalId: string;
        name: string;
        native: string;
        image: string;
        siteUrl: string;
        language: string;
      }
      const vaMap = new Map<string, MergedVoiceActor>();
      if (character.media?.edges) {
        for (const edge of character.media.edges) {
          if (edge.voiceActors) {
            for (const va of edge.voiceActors) {
              const key = va.id ? `person:a${va.id}` : `va:${va.name?.full || ''}`;
              if (!vaMap.has(key)) {
                vaMap.set(key, {
                  externalId: key,
                  name: va.name?.userPreferred || va.name?.full || '',
                  native: va.name?.native || '',
                  image: va.image?.large || va.image?.medium || '',
                  siteUrl: va.siteUrl || (va.id ? `https://anilist.co/staff/${va.id}` : ''),
                  language: va.languageV2 || 'Japanese',
                });
              }
            }
          }
        }
      }
      const persistedActors = await getCharacterActors(characterExternalId).catch(() => []);
      for (const a of persistedActors) {
        const live = vaMap.get(a.external_id);
        vaMap.set(a.external_id, {
          externalId: a.external_id,
          name: a.name || live?.name || '',
          native: a.name_native || live?.native || '',
          image: a.image_url || live?.image || '',
          siteUrl: live?.siteUrl || '',
          language: a.language || live?.language || 'Japanese',
        });
      }

      const vaByLang = new Map<string, MergedVoiceActor[]>();
      for (const va of vaMap.values()) {
        const rawLang = (va.language || 'Japanese').toLowerCase();
        const langKey = LANG_MAP[rawLang]?.code || rawLang.substring(0, 2).toUpperCase();
        if (!vaByLang.has(langKey)) vaByLang.set(langKey, []);
        vaByLang.get(langKey)!.push(va);
      }

      // Orden de prioridad para las pestañas de idiomas
      const langPriority = ['JP', 'ES', 'EN', 'IT', 'FR', 'DE', 'PT', 'KR', 'ZH'];
      const availableLangs = Array.from(vaByLang.keys()).sort((a, b) => {
        const idxA = langPriority.indexOf(a);
        const idxB = langPriority.indexOf(b);
        if (idxA !== -1 && idxB !== -1) return idxA - idxB;
        if (idxA !== -1) return -1;
        if (idxB !== -1) return 1;
        return a.localeCompare(b);
      });

      // ── ESPECIFICACIONES Y DATOS ──
      const statsCard = document.getElementById('char-stats-card')!;
      const statsList = document.getElementById('char-stats-list')!;
      let statsHtml = '';
      const addedLabels = new Set<string>();

      if (character.gender) {
        statsHtml += `<div class="media-stat-item"><span class="media-stat-label">Género</span><span class="media-stat-value">${escapeHtml(character.gender)}</span></div>`;
        addedLabels.add('gender');
        addedLabels.add('género');
      }
      if (character.age) {
        statsHtml += `<div class="media-stat-item"><span class="media-stat-label">Edad</span><span class="media-stat-value">${escapeHtml(String(character.age))}</span></div>`;
        addedLabels.add('age');
        addedLabels.add('edad');
      }
      if (character.bloodType) {
        statsHtml += `<div class="media-stat-item"><span class="media-stat-label">Grupo Sanguíneo</span><span class="media-stat-value">${escapeHtml(character.bloodType)}</span></div>`;
        addedLabels.add('bloodtype');
        addedLabels.add('grupo sanguíneo');
      }
      if (character.dateOfBirth && (character.dateOfBirth.day || character.dateOfBirth.month)) {
        const day = character.dateOfBirth.day ?? '?';
        const month = character.dateOfBirth.month ?? '?';
        const year = character.dateOfBirth.year ? `/${character.dateOfBirth.year}` : '';
        statsHtml += `<div class="media-stat-item"><span class="media-stat-label">Cumpleaños</span><span class="media-stat-value">${day}/${month}${year}</span></div>`;
        addedLabels.add('birthday');
        addedLabels.add('cumpleaños');
      }

      for (const stat of parsedStats) {
        const lowerLabel = stat.label.toLowerCase();
        if (addedLabels.has(lowerLabel)) continue;
        if (
          lowerLabel.includes('alias') ||
          lowerLabel.includes('nombre') ||
          lowerLabel.includes('name') ||
          lowerLabel.includes('aka')
        ) continue;

        let displayLabel = stat.label;
        if (lowerLabel === 'height') displayLabel = 'Estatura';
        else if (lowerLabel === 'weight') displayLabel = 'Peso';
        else if (lowerLabel === 'hair color') displayLabel = 'Pelo';
        else if (lowerLabel === 'eye color') displayLabel = 'Ojos';
        else if (lowerLabel === 'affiliations') displayLabel = 'Afiliación';
        else if (lowerLabel === 'bounty') displayLabel = 'Bounty';

        const values = stat.value.split(',').map(v => v.trim()).filter(v => v);
        const valueHtml = values.map(v => `<div>${escapeHtml(v)}</div>`).join('');

        statsHtml += `<div class="media-stat-item"><span class="media-stat-label">${escapeHtml(displayLabel)}</span><div class="media-stat-value">${valueHtml}</div></div>`;
        addedLabels.add(lowerLabel);
      }

      if (statsHtml) {
        statsList.innerHTML = statsHtml;
        statsList.style.display = 'block';
      } else {
        statsList.style.display = 'none';
      }

      // Render seiyūs por pestañas de idiomas (abajo del último apartado de datos)
      const seiyuSection = document.getElementById('char-seiyu-section');
      const seiyuTabsEl = document.getElementById('char-seiyu-lang-tabs');
      const seiyuListEl = document.getElementById('char-seiyu-list');

      if (availableLangs.length > 0 && seiyuSection && seiyuTabsEl && seiyuListEl) {
        let activeLang = availableLangs.includes('JP') ? 'JP' : availableLangs[0];

        function renderSeiyuList(langKey: string) {
          activeLang = langKey;

          seiyuTabsEl.innerHTML = availableLangs
            .map(lang => `
              <button
                type="button"
                class="char-seiyu-lang-btn ${lang === activeLang ? 'char-seiyu-lang-btn--active' : ''}"
                data-lang="${escapeHtml(lang)}"
              >
                ${escapeHtml(lang)}
              </button>
            `).join('');

          seiyuTabsEl.querySelectorAll('.char-seiyu-lang-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
              const target = e.currentTarget as HTMLElement;
              const lang = target.getAttribute('data-lang');
              if (lang) renderSeiyuList(lang);
            });
          });

          const vas = vaByLang.get(activeLang) || [];
          seiyuListEl.innerHTML = vas
            .map(va => `
              <div class="media-author-pill">
                ${va.image
                  ? `<img src="${safeUrl(va.image)}" alt="${escapeHtml(va.name)}" class="media-author-avatar" />`
                  : `<div class="media-author-avatar media-author-avatar--placeholder">${escapeHtml(va.name.charAt(0).toUpperCase())}</div>`}
                <div class="media-author-info">
                  ${va.siteUrl
                    ? `<a href="${safeUrl(va.siteUrl)}" target="_blank" rel="noopener noreferrer" class="media-author-name media-author-name--link" style="text-decoration: none; color: inherit;">${escapeHtml(va.name)}</a>`
                    : `<span class="media-author-name">${escapeHtml(va.name)}</span>`}
                  ${va.native && va.native !== va.name ? `<span class="media-author-role">${escapeHtml(va.native)}</span>` : ''}
                </div>
              </div>
            `).join('');
        }

        renderSeiyuList(activeLang);
        seiyuSection.style.display = 'block';
      } else if (seiyuSection) {
        seiyuSection.style.display = 'none';
      }

      if (statsHtml || availableLangs.length > 0) {
        statsCard.style.display = 'block';
      } else {
        statsCard.style.display = 'none';
      }

      // Biografía
      const bioSection = document.getElementById('char-bio-section')!;
      if (cleanDescription) {
        document.getElementById('char-description')!.innerHTML = sanitizeHtml(cleanDescription);
        bioSection.style.display = 'block';
      } else {
        bioSection.style.display = 'none';
      }

      // ── APARICIONES EN OBRAS ──
      const appearancesSection = document.getElementById('char-appearances-section')!;
      const appearancesGrid = document.getElementById('char-appearances-grid')!;
      const paginationEl = document.getElementById('appearances-pagination')!;
      const btnPrev = document.getElementById('btn-prev-appearances') as HTMLButtonElement;
      const btnNext = document.getElementById('btn-next-appearances') as HTMLButtonElement;
      const txtPage = document.getElementById('txt-appearances-page')!;

      // Local DB appearances win over the live AniList list whenever any
      // exist, same as the editor (CharacterPrEditorModal.tsx) — a manually
      // added or removed appearance must show here too, not just there.
      // AniList's own edges still resolve title/cover/date for whichever of
      // those local rows aren't cataloged locally yet.
      interface MergedAppearance {
        mediaId: string;
        title: string;
        cover: string | null;
        year: number | null;
        month: number | null;
        day: number | null;
        roleLabel: string;
      }
      const rawEdges = character.media?.edges || [];
      const anilistMediaCache: Record<string, { title: string; cover: string | null; year: number | null; month: number | null; day: number | null; role: string | null }> = {};
      for (const edge of rawEdges as any[]) {
        // AniList's own `type` field can't tell manga from light novel
        // (both are type MANGA — format NOVEL is what actually distinguishes
        // them) — using it bare here used to key light novel appearances as
        // "manga:<id>" instead of "lnovel:<id>", creating a second entry
        // alongside whatever this same work already existed as elsewhere.
        const extId = `${mapExternalFormatToType(edge.node.type, edge.node.format)}:${edge.node.id}`;
        anilistMediaCache[extId] = {
          title: edge.node.title.userPreferred || extId,
          cover: edge.node.coverImage?.large ?? null,
          year: edge.node.startDate?.year ?? null,
          month: edge.node.startDate?.month ?? null,
          day: edge.node.startDate?.day ?? null,
          role: edge.characterRole ?? null,
        };
      }

      const rawAppearances = await getCharacterAppearances(characterExternalId).catch(() => []);

      // Union of local rows + this live AniList lookup — local rows are
      // never dropped (so a manual edit in CharacterPrEditorModal sticks),
      // but any AniList appearance not already known locally gets added.
      // Just seeding once "while local is empty" (the previous approach)
      // stalled after the very first row got persisted from ANY source
      // (e.g. a media-page visit before ever opening the character page),
      // silently leaving the rest of AniList's list out forever.
      const localIds = new Set(rawAppearances.map(a => a.media_external_id));
      const newFromAniList = (rawEdges as any[])
        .map(edge => ({
          media_external_id: `${mapExternalFormatToType(edge.node.type, edge.node.format)}:${edge.node.id}`,
          relation_type: edge.characterRole ?? null,
          character_name: null as string | null,
          // Seeds a media_catalog stub (cover/type/title) the same way a
          // media page already does for its own relations, so this work has
          // a real card/link even before anyone visits its own page first.
          title: edge.node.title.userPreferred,
          cover: edge.node.coverImage?.large ?? null,
        }))
        .filter(a => !localIds.has(a.media_external_id));
      // Hard guarantee against duplicate cards for the same work — first
      // occurrence wins, so a local (possibly curator-edited) row always
      // beats whatever AniList's own live edge for that same id would say.
      const unionAppearances = Array.from(
        new Map([...rawAppearances, ...newFromAniList].map(a => [a.media_external_id, a])).values(),
      );
      if (newFromAniList.length > 0) {
        saveCharacterAppearances(characterExternalId, unionAppearances).catch(() => {});
      }

      const mergedAppearances: MergedAppearance[] = await Promise.all(unionAppearances.map(async (a): Promise<MergedAppearance> => {
        const entry = await getCatalogEntry(a.media_external_id).catch(() => null);
        const cached = anilistMediaCache[a.media_external_id];
        const relationType = a.relation_type ?? cached?.role ?? null;
        return {
          mediaId: a.media_external_id,
          title: entry?.title_main || cached?.title || a.media_external_id,
          cover: entry?.cover_url ?? cached?.cover ?? null,
          year: entry?.release_year ?? cached?.year ?? null,
          month: entry?.release_month ?? cached?.month ?? null,
          day: entry?.release_day ?? cached?.day ?? null,
          roleLabel: relationType ? (window.ROLE_LABELS[relationType] ?? relationType) : '',
        };
      }));

      // Newest release first, oldest last — same ordering as the character
      // editor's own appearances list (compareByReleaseDateDesc).
      mergedAppearances.sort((a, b) => compareByReleaseDateDesc(
        { release_year: a.year, release_month: a.month, release_day: a.day },
        { release_year: b.year, release_month: b.month, release_day: b.day },
      ));

      let currentPage = 1;
      const itemsPerPage = 8;

      function renderMediaPage() {
        const totalPages = Math.ceil(mergedAppearances.length / itemsPerPage);
        if (currentPage > totalPages) currentPage = totalPages || 1;

        const start = (currentPage - 1) * itemsPerPage;
        const slice = mergedAppearances.slice(start, start + itemsPerPage);

        appearancesGrid.innerHTML = slice
          .map(app => `
              <a href="/media?id=${encodeURIComponent(app.mediaId)}" class="media-relation-card">
                ${app.cover ? `<div class="media-relation-bg-layer"><img src="${safeUrl(app.cover)}" alt="" /></div>` : ''}
                <div class="media-relation-card-overlay"></div>
                <div class="media-relation-card-content">
                  <div class="media-relation-thumb">
                    ${app.cover ? `<img src="${safeUrl(app.cover)}" alt="${escapeHtml(app.title)}" loading="lazy" />` : ''}
                  </div>
                  <div class="media-relation-info">
                    <span class="media-relation-title">${escapeHtml(app.title)}</span>
                  </div>
                </div>
                ${app.roleLabel ? `<div class="media-relation-type">${escapeHtml(app.roleLabel)}</div>` : ''}
              </a>
            `)
          .join('');

        txtPage.textContent = `Página ${currentPage} de ${totalPages}`;
        btnPrev.disabled = currentPage === 1;
        btnNext.disabled = currentPage >= totalPages;
        paginationEl.style.display = totalPages > 1 ? 'flex' : 'none';
      }

      if (mergedAppearances.length > 0) {
        appearancesSection.style.display = 'block';
        renderMediaPage();

        btnPrev.onclick = () => {
          if (currentPage > 1) {
            currentPage--;
            renderMediaPage();
          }
        };
        btnNext.onclick = () => {
          const totalPages = Math.ceil(mergedAppearances.length / itemsPerPage);
          if (currentPage < totalPages) {
            currentPage++;
            renderMediaPage();
          }
        };
      } else {
        appearancesSection.style.display = 'none';
      }

      // Reacciones y Favorito
      const charKeyStr = characterExternalId;
      contentEl.setAttribute('data-char-key', charKeyStr);

      const favBtn = document.getElementById('char-fav-btn');
      const reactionBtns = document.querySelectorAll('.char-action-btn[data-reaction]');

      const allFavs = await readUserFavorites().catch(() => ({} as Record<string, string[]>));
      // read_user_favorites (Rust) keys its result by the singular type name
      // (fav_key_to_type("character_fav") === "character") — 'characters'/
      // 'characters_fav' never matched anything, so isFav was always false
      // and the button never reflected (or persisted to) the real list.
      const favList = allFavs['character'] || [];
      let isFav = Array.isArray(favList) && favList.includes(charKeyStr);

      function updateFavUI() {
        if (favBtn) {
          if (isFav) favBtn.classList.add('active');
          else favBtn.classList.remove('active');
        }
      }
      updateFavUI();

      if (favBtn) {
        favBtn.onclick = async () => {
          isFav = !isFav;
          updateFavUI();
          await syncFavorites('character', charKeyStr, isFav).catch(console.error);
        };
      }

      const savedLocal = await getCharacter(charKeyStr);
      let activeReaction = savedLocal?.reaction ?? null;

      function updateReactionUI() {
        reactionBtns.forEach(btn => {
          const r = btn.getAttribute('data-reaction');
          if (r === activeReaction) btn.classList.add('active');
          else btn.classList.remove('active');
        });
      }
      updateReactionUI();

      reactionBtns.forEach(btn => {
        btn.addEventListener('click', async () => {
          const r = btn.getAttribute('data-reaction');
          if (activeReaction === r) activeReaction = null;
          else activeReaction = r;
          updateReactionUI();
          await setCharacterReaction(charKeyStr, activeReaction).catch(console.error);
        });
      });

      loadingEl.style.display = 'none';
      contentEl.style.display = 'block';

      // Writes the sticky (local-preferred) values back, not AniList's raw
      // live copy — this used to blindly resave character.name.full/
      // .image/.native/.description on every single page view, silently
      // wiping out any edit made via the PR editor as soon as the user next
      // visited this same character page. Also persists the fully
      // consolidated alias list (aliases_csv/regex-extracted/etc.), not
      // just AniList's own raw alternative names.
      saveCharacter(
        charKeyStr,
        stickyName,
        stickyImage,
        stickyNameNative,
        allAliases.map(a => a.text).join(','),
        stickyBiography,
        character.gender,
        character.age,
        character.bloodType,
        character.dateOfBirth?.year ?? null,
        character.dateOfBirth?.month ?? null,
        character.dateOfBirth?.day ?? null,
      ).catch(() => {});

    } catch (err: any) {
      console.error('Error in loadCharacterData:', err);
      loadingEl.style.display = 'none';
      errorTextEl.textContent = err?.message || String(err);
      errorEl.style.display = 'flex';
    }
  }

  document.addEventListener('astro:page-load', () => {
    loadCharacterData();
  });
  if (document.readyState === 'complete' || document.readyState === 'interactive') {
    loadCharacterData();
  }
</script>
