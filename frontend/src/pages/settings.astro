---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/pages/settings.css";
import { getLang, useTranslations } from "../i18n/index";
import pkg from "../../package.json";
import {
  ICON_STAR,
  ICON_SETTINGS_APPEARANCE,
  ICON_SETTINGS_CONNECTIONS,
  ICON_SETTINGS_ENVIRONMENT,
  ICON_SETTINGS_NOVEDADES,
  ICON_UPLOAD_IMAGE,
  ICON_CHEVRON_LEFT,
  ICON_CHEVRON_RIGHT,
  ICON_RATING_FACES,
  ICON_GITHUB,
  ICON_HELP_CIRCLE,
  ICON_IMPORT_DOWNLOAD,
} from "../lib/shared/icon-strings";

const lang = getLang(Astro.url);
const t = useTranslations(lang);
const version = pkg.version;
---

<BaseLayout title={`${t.settings.title} — Metadea`} lang={lang}>
  <div class="settings-page">
    <div class="settings-container">
      <!-- Sidebar vertical -->
      <aside class="settings-sidebar">
        <span class="section-label settings-sidebar-label"
          >{t.settings.section_account}</span
        >
        <button class="settings-tab active" data-tab="profile">
          <Fragment set:html={ICON_SETTINGS_APPEARANCE} />
          {t.settings.section_appearance}
        </button>
        <button class="settings-tab" data-tab="application">
          <Fragment set:html={ICON_SETTINGS_CONNECTIONS} />
          {t.settings.tab_application}
        </button>

        <span
          class="section-label settings-sidebar-label"
          style="margin-top: 1rem; display: block;"
          >{t.settings.section_application}</span
        >
        <button class="settings-tab" data-tab="environment">
          <Fragment set:html={ICON_SETTINGS_ENVIRONMENT} />
          {t.settings.tab_environment}
        </button>
        <button class="settings-tab" data-tab="novedades">
          <Fragment set:html={ICON_SETTINGS_NOVEDADES} />
          {t.settings.tab_novedades}
        </button>
      </aside>

      <!-- Contenido -->
      <div class="settings-content">
        <!-- Tab: Apariencia (Perfil) -->
        <div class="settings-panel" id="panel-profile">
          <h2 class="settings-panel-title">{t.settings.section_appearance}</h2>

          <!-- Avatar + Banner en la misma fila -->
          <div class="profile-media-row">
            <!-- Nombre en la app -->
            <div class="settings-section settings-section--display-name">
              <h3 class="settings-section-title">Nombre en la app</h3>
              <input
                type="text"
                id="display-name-input"
                class="env-input"
                placeholder="Tu nombre..."
                maxlength="40"
                autocomplete="off"
                spellcheck="false"
                style="width: 100%; margin-top: 0.5rem;"
              />
              <p class="settings-hint" style="margin-top: 0.5rem;">Se muestra en tu perfil.</p>
            </div>

            <!-- Avatar -->
            <div class="settings-section settings-section--avatar">
              <h3 class="settings-section-title">{t.settings.avatar_title}</h3>
              <div class="avatar-preview-wrap" id="avatar-preview">
                <!-- populated by script -->
              </div>
              <div class="avatar-upload-btns">
                <button
                  class="btn btn--sm btn--secondary"
                  id="avatar-upload-btn">{t.settings.avatar_upload}</button
                >
                <button class="btn btn--sm btn--ghost" id="avatar-remove-btn"
                  >{t.settings.avatar_remove}</button
                >
              </div>
              <input type="file" id="avatar-input" accept="image/*" hidden />
            </div>

            <!-- Banner -->
            <div class="settings-section settings-section--banner">
              <h3 class="settings-section-title">{t.settings.banner_title}</h3>
              <div class="banner-drop-zone" id="banner-drop-zone">
                <div class="banner-drop-hint">
                  <Fragment set:html={ICON_UPLOAD_IMAGE} />
                  <span>{t.settings.banner_drag}</span>
                </div>
              </div>
              <div class="banner-actions">
                <button
                  class="btn btn--sm btn--secondary"
                  id="banner-upload-btn">{t.settings.banner_upload}</button
                >
                <button class="btn btn--sm btn--ghost" id="banner-remove-btn"
                  >{t.settings.banner_remove}</button
                >
              </div>
              <input type="file" id="banner-input" accept="image/*" hidden />
            </div>

            <!-- Fuente del nombre -->
            <div class="settings-section settings-section--font">
              <h3 class="settings-section-title">{t.settings.font_title}</h3>
              <div class="font-picker">
                <div class="font-preview" id="font-preview-name"></div>
                <div class="font-picker-controls">
                  <button
                    class="font-arrow"
                    id="font-prev"
                    aria-label={t.settings.font_prev}
                    set:html={ICON_CHEVRON_LEFT}
                  >
                  </button>
                  <span class="font-name-label" id="font-name-label"></span>
                  <button
                    class="font-arrow"
                    id="font-next"
                    aria-label={t.settings.font_next}
                    set:html={ICON_CHEVRON_RIGHT}
                  >
                  </button>
                </div>
              </div>
            </div>
          </div>

          <!-- Biografía y Sistema de Calificación lado a lado -->
          <div class="settings-divider settings-divider--row">
            <!-- Biografía -->
            <div class="settings-section flex-1">
              <h3 class="settings-section-title">{t.settings.bio_title}</h3>
              <textarea
                id="bio-textarea"
                class="settings-textarea"
                placeholder={t.settings.bio_placeholder}
                maxlength="500"
                rows="5"
              >
              </textarea>
              <div class="settings-bio-count">
                <span id="bio-char-count">0</span>/500
              </div>
            </div>

            <!-- Sistema de Calificación -->
            <div class="settings-section flex-1">
              <h3 class="settings-section-title">
                {t.settings.rating_system_title}
              </h3>
              <div class="rating-system-picker">
                <button
                  type="button"
                  class="rating-system-btn"
                  data-value="5-star"
                  title="5 estrellas"
                  set:html={ICON_STAR}
                >
                </button>
                <button
                  type="button"
                  class="rating-system-btn"
                  data-value="10-dec"
                  title="Nota sobre 10 (2 decimales)"
                >
                  <span class="rating-value-text">10.00</span>
                </button>
                <button
                  type="button"
                  class="rating-system-btn"
                  data-value="10"
                  title="Nota sobre 10 (Entero)"
                >
                  <span class="rating-value-text">10</span>
                </button>
                <button
                  type="button"
                  class="rating-system-btn"
                  data-value="3-emoji"
                  title="3 caritas (9, 6 y 3)"
                  set:html={ICON_RATING_FACES}
                >
                </button>
              </div>
            </div>
          </div>

          <!-- Color Personalizado y Selector de Fondo -->
          <div class="settings-divider settings-divider--row settings-divider--wrap">
            <!-- Color Personalizado -->
            <div class="settings-section settings-section--color">
              <h3 class="settings-section-title">
                {t.settings.custom_color_title}
              </h3>
              <p class="settings-hint">{t.settings.custom_color_hint}</p>
              <div class="color-picker-container">
                <input
                  type="color"
                  id="custom-color-input"
                  class="color-input"
                  value="#c084fc"
                />
                <div>
                  <p id="color-hex-display" class="settings-hex-display">
                    Actual: #c084fc
                  </p>
                  <button class="btn btn--sm btn--ghost" id="color-reset-btn"
                    >Restaurar defecto</button
                  >
                </div>
              </div>
            </div>

            <!-- Selector de Fondo Dinámico -->
            <div class="settings-section settings-section--theme">
              <h3 class="settings-section-title">
                {t.settings.appearance_bg_title}
              </h3>
              <p class="settings-hint">{t.settings.appearance_bg_hint}</p>
              <div class="theme-grid" id="theme-grid"></div>
            </div>
          </div>

          <!-- Sección de Actividad -->
          <div class="settings-divider">
            <h3 class="settings-section-title">
              {t.settings.activity_section}
            </h3>
            <div class="settings-checkbox-row">
              <div class="settings-checkbox-group">
                <label class="settings-checkbox-label">
                  <input
                    type="checkbox"
                    id="activity-batch-episodes"
                    class="settings-checkbox"
                  />
                  <span class="checkbox-label-text"
                    >{t.settings.activity_batch_episodes}</span
                  >
                </label>
                <p class="settings-hint">
                  {t.settings.activity_batch_episodes_hint}
                </p>
              </div>

              <div class="settings-checkbox-group">
                <label class="settings-checkbox-label">
                  <input
                    type="checkbox"
                    id="activity-adult-content"
                    class="settings-checkbox"
                  />
                  <span class="checkbox-label-text"
                    >{t.settings.activity_adult_content}</span
                  >
                </label>
                <p class="settings-hint">
                  {t.settings.activity_adult_content_hint}
                </p>
              </div>
            </div>
          </div>

          <!-- Cerrar sesión -->
          <div class="settings-divider">
            <button class="btn btn--sm btn--secondary settings-signout-btn" id="settings-signout-btn">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
              Cerrar sesión
            </button>
          </div>
        </div>

        <!-- Tab: Entorno -->
        <div class="settings-panel hidden" id="panel-environment">
          <h2 class="settings-panel-title">{t.settings.tab_environment}</h2>

          <div class="settings-section">
            <h3 class="settings-section-title">{t.settings.env_title}</h3>
            <p class="settings-hint">{t.settings.env_hint}</p>
            <button
              class="btn btn--sm btn--ghost"
              id="open-env-folder-btn"
              style="margin-bottom: 1rem;"
            >
              📁 {t.settings.env_open_folder}
            </button>

            <div class="env-services-grid">
              <!-- IGDB -->
              <div class="env-service-block">
                <div class="env-service-header" style="position: relative;">
                  <a
                    href="https://dev.twitch.tv/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="env-service-link"
                  >
                    <img
                      class="env-service-logo env-service-logo--lg"
                      src="/API/IGDB_logo.png"
                      alt="IGDB"
                    />
                  </a>
                  <button class="env-help-btn" data-help="igdb" title="¿Cómo obtener las claves de IGDB?" style="position: absolute; top: 0; right: 0; width: 24px; height: 24px; padding: 0; display: flex; align-items: center; justify-content: center; background: none; border: none; cursor: pointer;">
                    <Fragment set:html={ICON_HELP_CIRCLE} />
                  </button>
                </div>
                <div class="env-fields env-fields--row">
                  <div class="env-field">
                    <label class="env-label" for="igdb-client-id"
                      >{t.settings.env_igdb_client_id}</label
                    >
                    <input
                      class="env-input"
                      type="text"
                      id="igdb-client-id"
                      placeholder="xxxxxxxxxxxxxxxxxxxxxxxx"
                      autocomplete="off"
                      spellcheck="false"
                    />
                  </div>
                  <div class="env-field">
                    <label class="env-label" for="igdb-client-secret"
                      >{t.settings.env_igdb_client_secret}</label
                    >
                    <input
                      class="env-input"
                      type="password"
                      id="igdb-client-secret"
                      placeholder="••••••••••••••••••••••••"
                      autocomplete="off"
                    />
                  </div>
                </div>
              </div>

              <!-- TMDB -->
              <div class="env-service-block">
                <div class="env-service-header" style="position: relative;">
                  <a
                    href="https://www.themoviedb.org/settings/api"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="env-service-link"
                  >
                    <img
                      class="env-service-logo env-service-logo--lg"
                      src="/API/Tmdb.new.logo.png"
                      alt="TMDB"
                    />
                  </a>
                  <button class="env-help-btn" data-help="tmdb" title="¿Cómo obtener las claves de TMDB?" style="position: absolute; top: 0; right: 0; width: 24px; height: 24px; padding: 0; display: flex; align-items: center; justify-content: center; background: none; border: none; cursor: pointer;">
                    <Fragment set:html={ICON_HELP_CIRCLE} />
                  </button>
                </div>
                <div class="env-fields env-fields--row">
                  <div class="env-field">
                    <label class="env-label" for="tmdb-access-token"
                      >{t.settings.env_tmdb_access_token}</label
                    >
                    <input
                      class="env-input"
                      type="password"
                      id="tmdb-access-token"
                      placeholder="••••••••••••••••••••••••••••••••"
                      autocomplete="off"
                    />
                  </div>
                  <div class="env-field">
                    <label class="env-label" for="tmdb-api-key"
                      >{t.settings.env_tmdb_api_key}</label
                    >
                    <input
                      class="env-input"
                      type="password"
                      id="tmdb-api-key"
                      placeholder="••••••••••••••••••••••••••••••••"
                      autocomplete="off"
                    />
                  </div>
                </div>
              </div>

              <!-- Steam & AniList (Combined) -->
              <div class="env-service-block">
                <div class="env-fields env-fields--row">
                  <div class="env-field">
                    <div class="env-service-header env-service-header--compact" style="position: relative;">
                      <a
                        href="https://steamcommunity.com/dev/apikey"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="env-service-link"
                      >
                        <img
                          class="env-service-logo env-service-logo--lg"
                          src="/platforms/steam_logo.png"
                          alt="Steam"
                        />
                      </a>
                      <button class="env-help-btn" data-help="steam" title="¿Cómo obtener la clave de Steam?" style="position: absolute; top: 0; right: 0; width: 24px; height: 24px; padding: 0; display: flex; align-items: center; justify-content: center; background: none; border: none; cursor: pointer;">
                        <Fragment set:html={ICON_HELP_CIRCLE} />
                      </button>
                    </div>
                    <label class="env-label" for="steam-api-key"
                      >{t.settings.env_steam_api_key}</label
                    >
                    <input
                      class="env-input"
                      type="password"
                      id="steam-api-key"
                      placeholder="••••••••••••••••••••••••••••••••"
                      autocomplete="off"
                    />
                  </div>
                  <div class="env-field">
                    <div class="env-service-header env-service-header--compact">
                      <a
                        href="https://anilist.co/settings/developer"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="env-service-link"
                      >
                        <img
                          class="env-service-logo env-service-logo--lg"
                          src="/API/Anilist_logo.png"
                          alt="AniList"
                        />
                      </a>
                    </div>
                    <label class="env-label" for="anilist-client-id"
                      >Client ID</label
                    >
                    <input
                      class="env-input"
                      type="text"
                      id="anilist-client-id"
                      placeholder="Ej. 18343"
                      autocomplete="off"
                    />
                  </div>
                </div>
              </div>
            </div>

            <div class="settings-divider settings-divider--actions">
              <button class="btn btn--primary" id="env-save-btn"
                >{t.settings.env_save}</button
              >
              <button class="btn btn--ghost" id="env-clear-btn"
                >{t.settings.env_clear}</button
              >
            </div>
          </div>

          <!-- Local Routes -->
          <div class="settings-section" style="margin-top: 2rem;">
            <h3 class="settings-section-title">Rutas locales</h3>
            <p class="settings-hint">Carpetas locales para cada tipo de medio. Úsalas en la sección Biblioteca Local.</p>
            <div id="local-routes-list" style="display: flex; flex-direction: column; gap: 0.75rem; margin-top: 0.75rem;">
              <!-- Populated by JS -->
            </div>
          </div>
        </div>

        <!-- Tab: Conexiones -->
        <div class="settings-panel hidden" id="panel-application">
          <h2 class="settings-panel-title">{t.settings.tab_application}</h2>

          <div
            class="settings-section"
            style="max-width: 900px; margin-top: 1rem; display: flex; flex-direction: column; gap: 1rem;"
          >
            <div
              style="display: flex; flex-wrap: wrap; gap: 1rem; width: 100%;"
            >
              <!-- GitHub Auth Block -->
              <div class="settings-auth-block">
                <div class="settings-auth-info">
                  <div id="github-avatar-container" class="settings-auth-avatar">
                    <Fragment set:html={ICON_GITHUB} />
                  </div>
                  <div style="flex: 1;">
                    <div style="display: flex; align-items: center; gap: 0.5rem;">
                      <span class="settings-auth-name">GitHub</span>
                      <button class="settings-help-btn" data-help="github" title="¿Qué es GitHub?" style="width: 20px; height: 20px; padding: 0; display: flex; align-items: center; justify-content: center;">
                        <Fragment set:html={ICON_HELP_CIRCLE} />
                      </button>
                    </div>
                    <span id="github-user-status" class="settings-auth-status"
                      >No conectado</span
                    >
                  </div>
                </div>
                <button class="btn btn--sm btn--primary" id="github-login-btn"
                  >Conectar</button
                >
              </div>

              <!-- AniList Auth Block -->
              <div class="settings-auth-block">
                <div class="settings-auth-info">
                  <div id="anilist-avatar-container" class="settings-auth-avatar">
                    <img src="/API/Anilist_logo.png" style="width: 18px; height: 18px;" />
                  </div>
                  <div style="flex: 1;">
                    <div style="display: flex; align-items: center; gap: 0.5rem;">
                      <span class="settings-auth-name">AniList</span>
                      <button class="settings-help-btn" data-help="anilist" title="¿Qué es AniList?" style="width: 20px; height: 20px; padding: 0; display: flex; align-items: center; justify-content: center;">
                        <Fragment set:html={ICON_HELP_CIRCLE} />
                      </button>
                    </div>
                    <span id="anilist-user-status" class="settings-auth-status"
                      >No conectado</span
                    >
                  </div>
                </div>
                <div class="settings-auth-actions">
                  <button
                    class="btn btn--sm btn--secondary"
                    id="anilist-import-btn"
                    disabled
                  >
                    <Fragment set:html={ICON_IMPORT_DOWNLOAD} />
                    Importar
                  </button>
                  <button
                    class="btn btn--sm btn--primary"
                    id="anilist-login-btn"
                    >Desconectar</button
                  >
                </div>
              </div>

              <!-- Import Modal -->
              <div id="anilist-import-choose-modal" class="settings-import-choose-modal">
                <span class="settings-import-modal-title">¿Qué descargar de AniList?</span>

                <div class="settings-import-groups">
                  <div class="settings-import-group">
                    <span class="settings-import-group-label">Anime</span>
                    <div class="settings-import-format-grid">
                      <label class="settings-import-format-label">
                        <input type="checkbox" id="fmt-TV" checked />
                        <span class="settings-import-format-text">TV</span>
                      </label>
                      <label class="settings-import-format-label">
                        <input type="checkbox" id="fmt-TV_SHORT" checked />
                        <span class="settings-import-format-text">TV Short</span>
                      </label>
                      <label class="settings-import-format-label">
                        <input type="checkbox" id="fmt-MOVIE" checked />
                        <span class="settings-import-format-text">Movie</span>
                      </label>
                      <label class="settings-import-format-label">
                        <input type="checkbox" id="fmt-SPECIAL" checked />
                        <span class="settings-import-format-text">Special</span>
                      </label>
                      <label class="settings-import-format-label">
                        <input type="checkbox" id="fmt-OVA" checked />
                        <span class="settings-import-format-text">OVA</span>
                      </label>
                      <label class="settings-import-format-label">
                        <input type="checkbox" id="fmt-ONA" checked />
                        <span class="settings-import-format-text">ONA</span>
                      </label>
                      <label class="settings-import-format-label">
                        <input type="checkbox" id="fmt-MUSIC" />
                        <span class="settings-import-format-text">Music</span>
                      </label>
                    </div>
                  </div>

                  <div class="settings-import-group">
                    <span class="settings-import-group-label">Manga</span>
                    <div class="settings-import-format-grid">
                      <label class="settings-import-format-label">
                        <input type="checkbox" id="fmt-MANGA" checked />
                        <span class="settings-import-format-text">Manga</span>
                      </label>
                      <label class="settings-import-format-label">
                        <input type="checkbox" id="fmt-ONE_SHOT" checked />
                        <span class="settings-import-format-text">One-Shot</span>
                      </label>
                      <label class="settings-import-format-label">
                        <input type="checkbox" id="fmt-NOVEL" checked />
                        <span class="settings-import-format-text">Light Novel</span>
                      </label>
                    </div>
                  </div>
                </div>

                <div class="settings-import-actions">
                  <button
                    class="btn btn--sm btn--primary flex-1"
                    id="anilist-import-start-btn"
                  >Importar</button>
                  <button
                    class="btn btn--sm btn--secondary flex-1"
                    id="anilist-sync-start-btn"
                  >Sincronizar</button>
                  <button
                    class="btn btn--sm btn--ghost"
                    id="anilist-import-cancel-btn"
                  >Cancelar</button>
                </div>
              </div>
            </div>

            <!-- GitHub Device Flow modal -->
            <div id="github-device-modal" class="settings-modal">
              <span class="settings-modal-title">Iniciar Sesión en GitHub</span>
              <p class="settings-modal-hint">
                Entra en la web a continuación e introduce este código:
              </p>
              <div id="github-device-code-box" class="settings-modal-code">
                ----
              </div>
              <a
                href="https://github.com/login/device"
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn--sm btn--secondary settings-modal-link"
                >Abrir github.com/login/device</a
              >
              <button
                class="btn btn--sm btn--ghost"
                id="github-cancel-device-btn"
                style="width: 100%;">Cancelar</button
              >
            </div>

            <!-- AniList token prompt modal -->
            <div id="anilist-token-modal" class="settings-modal">
              <span class="settings-modal-title">Iniciar Sesión en AniList</span>
              <p class="settings-modal-hint">
                1. Haz clic en el botón de abajo para autorizar a Metadea en tu
                navegador.
              </p>
              <a
                href="#"
                id="anilist-auth-link"
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn--sm btn--secondary settings-modal-link"
                >Abrir página de autorización</a
              >
              <p class="settings-modal-hint settings-modal-hint--spaced">
                2. Copia el token/código largo que te da la web y pégalo aquí:
              </p>
              <input
                type="text"
                id="anilist-token-input"
                placeholder="Pega el token aquí..."
                class="settings-modal-input"
              />
              <div class="settings-modal-actions">
                <button
                  class="btn btn--sm btn--primary"
                  id="anilist-save-token-btn"
                  >Validar y guardar</button
                >
                <button
                  class="btn btn--sm btn--ghost"
                  id="anilist-cancel-token-btn"
                  >Cancelar</button
                >
              </div>
            </div>

            <!-- Help modals -->
            <div id="github-help-modal" class="settings-help-modal hidden">
              <div class="settings-help-modal-overlay"></div>
              <div class="settings-help-modal-content">
                <div class="settings-help-modal-header">
                  <h3>¿Qué es GitHub?</h3>
                  <button class="settings-help-modal-close" data-modal="github-help-modal">&times;</button>
                </div>
                <div class="settings-help-modal-body">
                  <p><strong>GitHub</strong> es una plataforma de control de versiones que permite colaborar en proyectos de código.</p>
                  <p>En Metadea, se usa para:</p>
                  <ul style="margin: 1rem 0 0 1.5rem; list-style: disc;">
                    <li><strong>Contribuir cambios:</strong> Proponer ediciones a los datos de animes, mangas y personajes de forma colaborativa</li>
                    <li><strong>Ver historial:</strong> Revisar todas las contribuciones y cambios realizados al proyecto</li>
                    <li><strong>Colaboración segura:</strong> Los cambios se revisan antes de aplicarse, manteniendo la calidad de los datos</li>
                  </ul>
                </div>
              </div>
            </div>

            <div id="anilist-help-modal" class="settings-help-modal hidden">
              <div class="settings-help-modal-overlay"></div>
              <div class="settings-help-modal-content">
                <div class="settings-help-modal-header">
                  <h3>¿Qué es AniList?</h3>
                  <button class="settings-help-modal-close" data-modal="anilist-help-modal">&times;</button>
                </div>
                <div class="settings-help-modal-body">
                  <p><strong>AniList</strong> es una base de datos comunitaria de animes, mangas y personajes muy popular en internet.</p>
                  <p>En Metadea, se usa para:</p>
                  <ul style="margin: 1rem 0 0 1.5rem; list-style: disc;">
                    <li><strong>Datos de animes y mangas:</strong> Sincronizar información como títulos, géneros, sinopsis y fechas</li>
                    <li><strong>Datos de personajes:</strong> Cargar información detallada de personajes, sus apareamientos y características</li>
                    <li><strong>Sincronizar biblioteca:</strong> Importar tu lista personal de animes y mangas desde AniList</li>
                  </ul>
                </div>
              </div>
            </div>

            <div id="igdb-help-modal" class="settings-help-modal hidden">
              <div class="settings-help-modal-overlay"></div>
              <div class="settings-help-modal-content">
                <div class="settings-help-modal-header">
                  <h3>¿Cómo obtener claves de IGDB?</h3>
                  <button class="settings-help-modal-close" data-modal="igdb-help-modal">&times;</button>
                </div>
                <div class="settings-help-modal-body">
                  <p><strong>IGDB</strong> es una base de datos de videojuegos. Para obtener tus claves:</p>
                  <ol style="margin: 1rem 0 0 1.5rem; list-style: decimal;">
                    <li>Ve a <a href="https://api-docs.igdb.com/#getting-started" target="_blank" rel="noopener noreferrer" style="color: var(--accent); text-decoration: underline;">api-docs.igdb.com</a></li>
                    <li>Sigue la guía de "Getting Started" en la documentación</li>
                    <li>Necesitarás obtener tu <strong>Client ID</strong> y <strong>Access Token</strong></li>
                    <li>Pega ambas claves en los campos correspondientes</li>
                  </ol>
                </div>
              </div>
            </div>

            <div id="tmdb-help-modal" class="settings-help-modal hidden">
              <div class="settings-help-modal-overlay"></div>
              <div class="settings-help-modal-content">
                <div class="settings-help-modal-header">
                  <h3>¿Cómo obtener claves de TMDB?</h3>
                  <button class="settings-help-modal-close" data-modal="tmdb-help-modal">&times;</button>
                </div>
                <div class="settings-help-modal-body">
                  <p><strong>TMDB</strong> (The Movie Database) es una base de datos de películas y series. Para obtener tus claves:</p>
                  <ol style="margin: 1rem 0 0 1.5rem; list-style: decimal;">
                    <li>Ve a <a href="https://developer.themoviedb.org/docs/getting-started" target="_blank" rel="noopener noreferrer" style="color: var(--accent); text-decoration: underline;">developer.themoviedb.org</a></li>
                    <li>Sigue la guía de "Getting Started" en la documentación</li>
                    <li>Necesitarás crear una cuenta si no la tienes</li>
                    <li>Obtén tu <strong>API Key</strong> y <strong>Access Token</strong></li>
                    <li>Pega ambas claves en los campos correspondientes</li>
                  </ol>
                  <p style="margin-top: 1rem; font-size: 0.9em; color: var(--text-muted);">Nota: Ambos campos son necesarios para acceso completo a TMDB</p>
                </div>
              </div>
            </div>

            <div id="steam-help-modal" class="settings-help-modal hidden">
              <div class="settings-help-modal-overlay"></div>
              <div class="settings-help-modal-content">
                <div class="settings-help-modal-header">
                  <h3>¿Cómo obtener clave de Steam?</h3>
                  <button class="settings-help-modal-close" data-modal="steam-help-modal">&times;</button>
                </div>
                <div class="settings-help-modal-body">
                  <p><strong>Steam</strong> es la plataforma de distribución de videojuegos de Valve. Para obtener tu clave API:</p>
                  <ol style="margin: 1rem 0 0 1.5rem; list-style: decimal;">
                    <li>Necesitas una <strong>cuenta de Steam</strong> con historial de compras</li>
                    <li>Ve a <a href="https://steamcommunity.com/dev/apikey" target="_blank" rel="noopener noreferrer" style="color: var(--accent); text-decoration: underline;">steamcommunity.com/dev/apikey</a></li>
                    <li>Inicia sesión si es necesario</li>
                    <li>Introduce un <strong>nombre de dominio</strong> (puede ser localhost para desarrollo local)</li>
                    <li>Lee y acepta el acuerdo de licencia</li>
                    <li>Se generará tu <strong>API Key</strong> automáticamente</li>
                    <li>Copia la clave y pégala en el campo de abajo</li>
                  </ol>
                  <p style="margin-top: 1rem; font-size: 0.9em; color: var(--text-muted);">⚠️ No compartas tu API Key con otros; es personal y única para tu cuenta</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Tab: Novedades -->
        <div class="settings-panel hidden" id="panel-novedades">
          <h2 class="settings-panel-title">{t.settings.tab_novedades}</h2>

          <div
            class="settings-section"
            style="max-width: 600px; margin-top: 1rem; display: flex; flex-direction: column; gap: 1rem;"
          >
            <p class="settings-hint" style="margin-bottom: 0.5rem;">
              Mantente al día con las últimas versiones y mejoras de la
              aplicación.
            </p>

            <div class="settings-version-card">
              <div>
                <span class="settings-auth-name">{t.settings.app_version_label}</span>
                <span
                  class="app-curr-ver settings-auth-status settings-auth-status--mono"
                  data-version={version}
                ></span>
              </div>
              <button
                class="btn btn--sm btn--secondary"
                id="app-check-update-btn">{t.settings.app_check_update}</button
              >
            </div>
            <div
              id="updater-status-text"
              style="font-size: 0.8rem; color: var(--text-muted); text-align: center; display: none; margin-top: 0.5rem;"
            >
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Toast -->
  <div class="settings-toast" id="settings-toast">{t.settings.env_saved}</div>
</BaseLayout>

<script>
  import { getAuthToken, clearAuthToken } from "../lib/tauri";
  import { decodeJwtPayload } from "../lib/profile/utils";
  import { initAvatar } from "../lib/settings/avatar";
  import { initBanner } from "../lib/settings/banner";
  import { initThemePicker } from "../lib/settings/theme";
  import { initEnvironment } from "../lib/settings/environment";
  import { initFontPicker } from "../lib/settings/fonts";
  import { initGitHubAuth } from "../lib/settings/github";
  import { initAniListAuth } from "../lib/settings/anilist";
  import { initAniListImportUI } from "../lib/settings/anilist-import-ui";
  import { initDisplayName } from "../lib/settings/display-name";
  import { initRatingSystem } from "../lib/settings/rating-system";
  import { initCustomColor } from "../lib/settings/custom-color";
  import { initActivitySettings } from "../lib/settings/activity";
  import { initBio } from "../lib/settings/bio";
  import { initUpdater } from "../lib/settings/updater";
  import { initSettingsTabs } from "../lib/settings/tabs";
  import { getT } from "../i18n/client";

  function showToast(msg?: string) {
    const clientT = getT();
    const el = document.getElementById("settings-toast")!;
    el.textContent = msg || clientT.settings.env_saved;
    el.classList.add("visible");
    setTimeout(() => el.classList.remove("visible"), 2000);
  }

  function setupHelpModals() {
    const allBtns = document.querySelectorAll("button[data-help]");
    console.log("Setting up help modals, found", allBtns.length, "buttons with data-help");

    allBtns.forEach((btn) => {
      btn.addEventListener("click", function(e) {
        console.log("Help button clicked!");
        e.preventDefault();
        e.stopPropagation();
        const helpType = this.getAttribute("data-help");
        const modalId = helpType + "-help-modal";
        const modal = document.getElementById(modalId);
        console.log("Looking for modal:", modalId, "Found:", modal ? "yes" : "no");
        if (modal) {
          modal.classList.remove("hidden");
          console.log("Modal opened");
        }
      });
    });

    document.querySelectorAll(".settings-help-modal-close").forEach(btn => {
      btn.addEventListener("click", (e) => {
        const modal = (e.target as HTMLElement).closest(".settings-help-modal");
        if (modal) modal.classList.add("hidden");
      });
    });

    document.querySelectorAll(".settings-help-modal-overlay").forEach(overlay => {
      overlay.addEventListener("click", (e) => {
        const modal = (e.target as HTMLElement).closest(".settings-help-modal");
        if (modal) modal.classList.add("hidden");
      });
    });
  }

  // Setup help modals on initial page load
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupHelpModals);
  } else {
    setupHelpModals();
  }

  document.addEventListener("astro:page-load", async () => {
    // This listener is registered once and never removed, but astro:page-load
    // fires on every SPA navigation, not just to this page — once /settings
    // has been visited once, every future navigation anywhere else re-ran
    // this handler, including the unconditional redirect-to-/login below if
    // the session check ever failed. Bail out if we're not actually on
    // /settings (see the same fix on profile.astro/character.astro).
    if (!document.querySelector('.settings-page')) return;

    const session = await getAuthToken().catch(() => null);
    if (!session?.token) {
      window.location.replace("/login");
      return;
    }

    const payload = decodeJwtPayload(session.token);
    const googleAvatar = payload.avatar as string | null;
    const username = session.username;

    initAvatar(googleAvatar, username, showToast);
    initBanner(showToast);
    initFontPicker(username, showToast);
    initThemePicker(showToast);
    initEnvironment(showToast);
    initGitHubAuth();
    initAniListAuth();
    initAniListImportUI(showToast);
    initDisplayName(showToast);
    initRatingSystem(showToast);
    initCustomColor(showToast);
    initActivitySettings(showToast);
    initBio();

    document.getElementById("settings-signout-btn")?.addEventListener("click", async () => {
      await clearAuthToken().catch(() => {});
      window.location.href = "/";
    });

    const defaultVersion =
      (document.querySelector(".app-curr-ver") as HTMLElement | null)?.dataset.version || "0.1.9";
    initUpdater(defaultVersion);
    initSettingsTabs();

    // Re-setup help modals on SPA navigation
    setupHelpModals();
  });
</script>
