---
// Punto de entrada: inicializa la DB y comprueba sesión
---
<html>
  <head>
    <meta charset="utf-8" />
    <style>body { margin: 0; background: #0a0a0a; }</style>
    <script is:inline>
      var token = localStorage.getItem('auth_token');
      var last = localStorage.getItem('metadea_last_visited_path');
      var destination = token ? (last && last !== '/' ? last : '/home') : '/login';
      window.location.replace(destination);
    </script>
  </head>
  <body>
  </body>
</html>
