---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/pages/author.css';
import { getLang } from '../i18n/index';

const lang = getLang(Astro.url);
---

<BaseLayout title="Author Details — Metadea" lang={lang} activePage="search">
  <div class="author-page-container">
    
    <!-- Back Button -->
    <div class="back-btn-wrap">
      <a href="#" onclick="history.back(); return false;" class="btn btn--sm btn--secondary back-btn-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        Go back
      </a>
    </div>

    <!-- Loading State -->
    <div id="author-loading" class="author-empty-box">
      <p>Loading author details...</p>
    </div>

    <!-- Error State -->
    <div id="author-error" class="author-error-box" style="display: none;">
      <p style="font-weight: 700; margin-bottom: 0.5rem;">Error loading author details</p>
      <p id="author-error-text" style="font-size: 0.85rem; opacity: 0.8;"></p>
    </div>

    <!-- Author Content -->
    <div id="author-content" class="author-detail-layout" style="display: none;">
      
      <!-- Left Column: Sidebar -->
      <div class="author-sidebar-col">
        <!-- Author Photo -->
        <div class="author-avatar-wrap" id="author-avatar-container">
          <!-- Populated dynamically -->
        </div>

        <!-- Sidebar Stats Card -->
        <div class="author-stats-card" id="author-stats-card" style="display: none;">
          <div class="author-sidebar-stats-list" id="author-stats-list">
            <!-- Populated dynamically -->
          </div>
        </div>
      </div>

      <!-- Right Column: Main Content -->
      <div class="author-main-col">

        <!-- Names Header -->
        <div class="author-names-header">
          <h1 class="author-name-title" id="author-name-full"></h1>
          <p class="author-name-native" id="author-name-native" style="display: none; margin: 0;"></p>
          <div class="author-alt-names" id="author-alt-names" style="display: none;">
            <!-- Populated dynamically -->
          </div>
        </div>

        <!-- Biography Section -->
        <div class="author-section-box" id="author-bio-section" style="display: none;">
          <h2 class="author-section-title">Biography</h2>
          <div class="author-description-text" id="author-description"></div>
        </div>

        <!-- Works Section -->
        <div class="author-section-box" id="author-works-section" style="display: none;">
          <h2 class="author-section-title">Works</h2>
          <div class="author-works-grid" id="author-works-grid"></div>
        </div>

      </div>

    </div>
  </div>
</BaseLayout>

<script>
  import { fetchAniListStaffDetail } from '../lib/search/providers/anilist';
  import { fetchOpenLibAuthorFullDetail, bookIdFromWorkKey } from '../lib/search/providers/openlibrary';
  import { mapExternalFormatToType } from '../lib/media/mapper-utils';
  import { needsResync } from '../lib/media/media-status';
  import { sanitizeHtml, escapeHtml, safeUrl } from '../lib/shared/sanitize-html';
  import {
    getAuthor,
    getAuthorWorks,
    saveAuthorProfileAndRelations,
    getSyncState,
    markSynced,
    markSyncFailed,
    type DbMediaAuthor,
    type AuthorWorkRelation,
    type AuthorWork,
  } from '../lib/tauri';

  interface AuthorRenderData {
    name: string;
    nameNative?: string | null;
    aliases: string[];
    image?: string | null;
    biographyHtml?: string | null; // pre-sanitized, ready for innerHTML
    birthDate?: string | null;
    deathDate?: string | null;
    works: { url: string; title: string; cover?: string | null; role?: string | null }[];
  }

  // Purely local reconstruction — used both when sync_state says a resync
  // isn't due yet, and as a graceful degrade if a due live fetch fails but a
  // local copy still exists (same idea as mediaService.ts's resync backoff).
  async function localAuthorToRenderData(externalId: string, a: DbMediaAuthor): Promise<AuthorRenderData> {
    const works: AuthorWork[] = await getAuthorWorks(externalId).catch(() => []);
    return {
      name: a.name,
      nameNative: a.name_native ?? null,
      aliases: a.aliases_csv ? a.aliases_csv.split(',').map(s => s.trim()).filter(Boolean) : [],
      image: a.image ?? null,
      biographyHtml: a.biography ? sanitizeHtml(a.biography) : null,
      birthDate: a.birth_date ?? null,
      deathDate: a.death_date ?? null,
      works: works.map(w => ({
        url: `/media?id=${w.media_external_id}`,
        title: w.title || w.media_external_id,
        cover: w.cover ?? null,
        role: w.role ?? null,
      })),
    };
  }

  // Live AniList staff fetch — persists the full profile (name_native/
  // aliases/biography, previously never cached at all) and its works list.
  async function fetchLiveAniListStaff(externalId: string, idVal: string): Promise<AuthorRenderData | null> {
    const staffId = parseInt(idVal.slice(1), 10);
    if (isNaN(staffId)) throw new Error('Invalid AniList staff numerical ID');

    const staff = await fetchAniListStaffDetail(staffId);
    if (!staff) return null;

    const edges = staff.staffMedia?.edges || [];
    const works = edges.map(edge => {
      const item = edge.node;
      const type = mapExternalFormatToType(item.type, item.format);
      const title = item.title.english || item.title.romaji || 'Unknown Title';
      return { url: `/media?id=${type}:${item.id}`, title, cover: item.coverImage?.medium || null, role: edge.staffRole || null };
    });

    const dbAuthor: DbMediaAuthor = {
      external_id: externalId,
      name: staff.name.full,
      image: staff.image?.large || null,
      role: null,
      url: `/author?id=${externalId}`,
      name_native: staff.name.native || null,
      aliases_csv: staff.name.alternative?.length ? staff.name.alternative.join(',') : null,
      biography: staff.description || null,
      birth_date: null,
      death_date: null,
    };
    const dbRelations: AuthorWorkRelation[] = works.map(w => ({
      media_external_id: w.url.slice('/media?id='.length),
      role: w.role,
      title: w.title,
      cover: w.cover,
    }));
    saveAuthorProfileAndRelations(dbAuthor, dbRelations).catch(console.error);

    return {
      name: staff.name.full,
      nameNative: staff.name.native,
      aliases: staff.name.alternative || [],
      image: staff.image?.large || null,
      biographyHtml: staff.description ? sanitizeHtml(staff.description) : null,
      birthDate: null,
      deathDate: null,
      works,
    };
  }

  // Live OpenLibrary author fetch — same idea, persists birth/death dates too.
  async function fetchLiveOpenLibraryAuthor(externalId: string, idVal: string): Promise<AuthorRenderData | null> {
    const author = await fetchOpenLibAuthorFullDetail(idVal);
    if (!author) return null;

    const authorPhotoUrl = author.photos?.length ? `https://covers.openlibrary.org/a/id/${author.photos[0]}-L.jpg` : null;
    const bioText = (typeof author.bio === 'object' ? author.bio?.value : author.bio) || null;
    const works = (author.works || []).map(work => ({
      url: `/media?id=book:${bookIdFromWorkKey(work.key)}`,
      title: work.title,
      cover: work.covers?.length ? `https://covers.openlibrary.org/b/id/${work.covers[0]}-M.jpg` : null,
      role: 'AUTHOR',
    }));

    const dbAuthor: DbMediaAuthor = {
      external_id: externalId,
      name: author.name,
      image: authorPhotoUrl,
      role: null,
      url: `/author?id=${externalId}`,
      name_native: null,
      aliases_csv: null,
      biography: bioText,
      birth_date: author.birth_date || null,
      death_date: author.death_date || null,
    };
    const dbRelations: AuthorWorkRelation[] = works.map(w => ({
      media_external_id: w.url.slice('/media?id='.length),
      role: w.role,
      title: w.title,
      cover: w.cover,
    }));
    saveAuthorProfileAndRelations(dbAuthor, dbRelations).catch(console.error);

    return {
      name: author.name,
      nameNative: null,
      aliases: [],
      image: authorPhotoUrl,
      biographyHtml: bioText ? sanitizeHtml(bioText) : null,
      birthDate: author.birth_date || null,
      deathDate: author.death_date || null,
      works,
    };
  }

  function renderAuthor(data: AuthorRenderData) {
    document.getElementById('author-name-full')!.textContent = data.name;
    const nativeEl = document.getElementById('author-name-native')!;
    if (data.nameNative) {
      nativeEl.textContent = data.nameNative;
      nativeEl.style.display = 'block';
    } else {
      nativeEl.style.display = 'none';
    }

    const avatarContainer = document.getElementById('author-avatar-container')!;
    avatarContainer.innerHTML = data.image
      ? `<img src="${safeUrl(data.image)}" alt="${escapeHtml(data.name)}" class="author-avatar-img" />`
      : `<div class="author-avatar-placeholder">No Image</div>`;

    const altNamesContainer = document.getElementById('author-alt-names')!;
    if (data.aliases.length > 0) {
      altNamesContainer.innerHTML = data.aliases.map(alt => `<span class="author-alt-name-tag">${escapeHtml(alt)}</span>`).join('');
      altNamesContainer.style.display = 'flex';
    } else {
      altNamesContainer.style.display = 'none';
    }

    const statsList = document.getElementById('author-stats-list')!;
    statsList.innerHTML = '';
    let hasStats = false;
    if (data.birthDate) {
      statsList.innerHTML += `<div class="author-sidebar-stat-item"><span class="author-stat-label">Birth Date</span><span class="author-stat-value">${escapeHtml(data.birthDate)}</span></div>`;
      hasStats = true;
    }
    if (data.deathDate) {
      statsList.innerHTML += `<div class="author-sidebar-stat-item"><span class="author-stat-label">Death Date</span><span class="author-stat-value">${escapeHtml(data.deathDate)}</span></div>`;
      hasStats = true;
    }
    document.getElementById('author-stats-card')!.style.display = hasStats ? 'block' : 'none';

    const bioSection = document.getElementById('author-bio-section')!;
    if (data.biographyHtml) {
      document.getElementById('author-description')!.innerHTML = data.biographyHtml;
      bioSection.style.display = 'block';
    } else {
      bioSection.style.display = 'none';
    }

    const worksGrid = document.getElementById('author-works-grid')!;
    const worksSection = document.getElementById('author-works-section')!;
    if (data.works.length > 0) {
      worksGrid.innerHTML = data.works
        .map(w => {
          const coverImg = w.cover
            ? `<img src="${safeUrl(w.cover)}" alt="${escapeHtml(w.title)}" class="author-work-cover" />`
            : `<div class="author-work-placeholder">${escapeHtml(w.title)}</div>`;
          return `
            <a href="${w.url}" class="author-work-card">
              <div class="author-work-cover-wrap">
                ${coverImg}
              </div>
              <span class="author-work-title" title="${escapeHtml(w.title)}">${escapeHtml(w.title)}</span>
              ${w.role ? `<span class="author-work-role">${escapeHtml(w.role)}</span>` : ''}
            </a>
          `;
        })
        .join('');
      worksSection.style.display = 'block';
    } else {
      worksSection.style.display = 'none';
    }
  }

  async function loadAuthorData() {
    const loadingEl = document.getElementById('author-loading')!;
    const errorEl = document.getElementById('author-error')!;
    const errorTextEl = document.getElementById('author-error-text')!;
    const contentEl = document.getElementById('author-content')!;

    const urlParams = new URLSearchParams(window.location.search);
    const externalId = urlParams.get('id') ?? '';

    if (!externalId) {
      loadingEl.style.display = 'none';
      errorTextEl.textContent = 'Invalid or missing Author ID parameter';
      errorEl.style.display = 'block';
      return;
    }

    try {
      const parts = externalId.split(':');
      const provider = parts[0];
      const idVal = parts.slice(1).join(':');

      // "person:a{id}" (AniList staff) / "person:t{id}" (TMDB staff) share
      // the person: namespace — the leading letter is what keeps the two
      // providers' otherwise-independent numeric ids from colliding, and
      // decides which provider's detail fetch runs below.
      if (provider === 'person' && idVal.startsWith('t')) {
        // TMDB doesn't have its own person-detail page/fetch built yet —
        // fail clearly instead of falling through to the AniList branch
        // below with a mismatched id.
        throw new Error('La ficha de personal de TMDB aún no está disponible.');
      }
      if (provider !== 'person' && provider !== 'author') {
        throw new Error(`Unsupported author provider: ${provider}`);
      }

      // sync_state gates the live fetch the same way character.astro does —
      // this page used to hit AniList/OpenLibrary unconditionally on every
      // single visit regardless of how fresh the local copy already was.
      const localAuthor = await getAuthor(externalId).catch(() => null);
      const syncState = await getSyncState(externalId).catch(() => null);
      const dueForResync = needsResync(syncState ? {
        last_synced_at: syncState.last_synced_at,
        sync_failed_count: syncState.sync_failed_count,
      } : null);

      let data: AuthorRenderData;
      if (dueForResync || !localAuthor) {
        const live = provider === 'person'
          ? await fetchLiveAniListStaff(externalId, idVal)
          : await fetchLiveOpenLibraryAuthor(externalId, idVal);

        if (live) {
          data = live;
          markSynced(externalId).catch(() => {});
        } else if (localAuthor) {
          // Live fetch failed but a local copy exists — degrade instead of a
          // hard error, same backoff-on-failure behavior mediaService.ts uses.
          markSyncFailed(externalId, 'Live fetch returned no data').catch(() => {});
          data = await localAuthorToRenderData(externalId, localAuthor);
        } else {
          throw new Error(provider === 'person' ? 'AniList staff member not found' : 'OpenLibrary author details not found');
        }
      } else {
        // Not due for a resync and a local copy already exists — skip the
        // live call entirely instead of re-fetching on every page visit.
        data = await localAuthorToRenderData(externalId, localAuthor);
      }

      renderAuthor(data);

      loadingEl.style.display = 'none';
      contentEl.style.display = 'grid';

    } catch (err: any) {
      console.error(err);
      loadingEl.style.display = 'none';
      errorTextEl.textContent = err.message || 'Error communicating with external API';
      errorEl.style.display = 'block';
    }
  }

  // Load immediately
  loadAuthorData();
</script>
