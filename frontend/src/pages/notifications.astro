---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLang, useTranslations } from '../i18n/index';

const lang = getLang(Astro.url);
const t    = useTranslations(lang);
---

<BaseLayout title={`${t.notifications.title} — Metadea`} lang={lang} activePage="notifications">
  <main class="placeholder-page">
    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--text-dim)">
      <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
      <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
    </svg>
    <h1 class="placeholder-title">{t.notifications.title}</h1>
    <p class="placeholder-text">{t.notifications.coming_soon}</p>
  </main>
</BaseLayout>
