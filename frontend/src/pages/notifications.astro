---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/pages/media.css';
import '../styles/pages/notifications.css';
import { getLang, useTranslations } from '../i18n/index';
import { NotificationsPanel } from '../components/notifications/NotificationsPanel';

const lang = getLang(Astro.url);
const t    = useTranslations(lang);
---

<BaseLayout title={`${t.notifications.title} — Metadea`} lang={lang} activePage="notifications">
  <NotificationsPanel client:load i18n={{ media: t.media, discord: t.discord, notifications: t.notifications }} />
</BaseLayout>
