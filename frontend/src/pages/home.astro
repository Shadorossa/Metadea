---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/pages/home.css';
import { getLang, useTranslations } from '../i18n/index';
import { API_URL } from '../lib/config';

const lang = getLang(Astro.url);
const t    = useTranslations(lang);
---

<BaseLayout title="Metadea" lang={lang} activePage="home">
  <main class="flex flex-col items-center justify-center min-h-screen gap-6">
    <h1 class="text-4xl font-bold tracking-tight">
      {t.home.title}
    </h1>

    <div id="google-link-container" class="animate-fade-in" style="display: none;">
      <a id="home-google-btn" class="google-btn" href="#" style="max-width: 280px;">
        <svg width="18" height="18" viewBox="0 0 48 48">
          <path fill="#FFC107" d="M43.6 20.1H42V20H24v8h11.3C33.7 32.7 29.2 36 24 36c-6.6 0-12-5.4-12-12s5.4-12 12-12c3.1 0 5.8 1.1 8 2.9l5.7-5.7C34.5 6.5 29.5 4 24 4 12.9 4 4 12.9 4 24s8.9 20 20 20 20-8.9 20-20c0-1.3-.1-2.7-.4-3.9z"/>
          <path fill="#FF3D00" d="M6.3 14.7l6.6 4.8C14.7 16.1 19 13 24 13c3.1 0 5.8 1.1 8 2.9l5.7-5.7C34.5 6.5 29.5 4 24 4 16.3 4 9.7 8.3 6.3 14.7z"/>
          <path fill="#4CAF50" d="M24 44c5.2 0 9.9-2 13.4-5.2l-6.2-5.2C29.2 35.3 26.7 36 24 36c-5.2 0-9.6-3.3-11.3-8H6.3C9.7 36.5 16.3 44 24 44z"/>
          <path fill="#1976D2" d="M43.6 20.1H42V20H24v8h11.3c-.8 2.3-2.3 4.2-4.3 5.6l6.2 5.2C41.4 35.5 44 30.2 44 24c0-1.3-.1-2.7-.4-3.9z"/>
        </svg>
        Vincular con Google
      </a>
    </div>

    <div id="home-calendar" class="home-calendar-section"></div>
  </main>

  <script>
    import { getAuthToken } from '../lib/tauri';
    import { API_URL } from '../lib/config';
    import { renderReleaseCalendar } from '../lib/home/render-calendar';

    async function checkSession() {
      const session = await getAuthToken();
      if (session && session.token === 'offline_token') {
        const container = document.getElementById('google-link-container');
        if (container) {
          container.style.display = 'block';
        }
      }
    }

    document.addEventListener('astro:page-load', () => {
      document.getElementById('home-google-btn')?.addEventListener('click', (e) => {
        e.preventDefault();
        window.location.href = `${API_URL}/api/auth/google`;
      });

      checkSession();

      const calendarEl = document.getElementById('home-calendar');
      if (calendarEl) renderReleaseCalendar(calendarEl).catch(console.error);
    });
  </script>
</BaseLayout>
