---
import '../styles/global.css';
import '../styles/components.css';
import '../styles/navbar.css';
import { getLang, useTranslations } from '../i18n/index';
import Navbar from '../components/Navbar.astro';

const lang = getLang(Astro.url);
const t = useTranslations(lang);
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Metadea</title>
  </head>
  <body>
    <Navbar activePage="home" />

    <main class="flex items-center justify-center min-h-[calc(100vh-3.5rem)]">
      <h1 class="text-4xl font-bold tracking-tight" style="color: var(--text-main)">{t.home.title}</h1>
    </main>
  </body>
</html>
