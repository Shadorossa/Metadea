---
import { getLang, useTranslations } from '../i18n/index';
import { API_URL } from '../lib/config';
import '../styles/core/global.css';
import '../styles/components/components.css';
import '../styles/pages/login.css';

const lang = getLang(Astro.url);
const t    = useTranslations(lang);
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Metadea — {t.auth.login}</title>
  </head>
  <body class="login-body">
    <div class="login-card">
      <span class="login-logo">Metadea</span>
      <p class="login-subtitle">Tu biblioteca personal de medios</p>

      <form id="login-form" style="width: 100%; display: flex; flex-direction: column; gap: 0.75rem;">
        <input 
          type="text" 
          id="username-input" 
          class="input-dark" 
          placeholder="Nombre de usuario" 
          required 
          minlength="3" 
          maxlength="20"
        />
        <button type="submit" class="btn btn--primary" style="justify-content: center; width: 100%;">
          Comenzar
        </button>
      </form>

      <p id="error-msg" class="login-error" style="display:none"></p>
    </div>

    <script>
      import { storeAuthToken, initTauriDatabase } from '../lib/tauri';

      const form = document.getElementById('login-form');
      const input = document.getElementById('username-input') as HTMLInputElement;
      const errorMsg = document.getElementById('error-msg');

      // This is a standalone page (no BaseLayout), which is normally the one
      // that calls initTauriDatabase() on every page load — every invoke()
      // call (see lib/tauri/core.ts) awaits a promise that only resolves once
      // that runs, so without this, storeAuthToken's invoke('store_auth_token')
      // below would hang forever with no error and no visible feedback.
      initTauriDatabase().catch(e => console.error('Failed to init Tauri database:', e));

      form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const username = input.value.trim();
        if (username) {
          try {
            await storeAuthToken('offline_token', username);
            window.location.replace('/home');
          } catch (err) {
            if (errorMsg) {
              errorMsg.textContent = (err instanceof Error ? err.message : null) || 'Error al iniciar sesión';
              errorMsg.style.display = 'block';
            }
          }
        }
      });
    </script>
  </body>
</html>
