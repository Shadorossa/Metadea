---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/media.css';
import { getLang } from '../i18n/index';

const lang = getLang(Astro.url);
---

<BaseLayout title="Media — Metadea" lang={lang}>
  <div class="media-page">
    <div id="media-root"></div>
  </div>
</BaseLayout>

<script>
  import { fetchAniListDetail } from '../lib/search/providers/anilist';
  import type { AniListMediaDetail } from '../lib/search/providers/anilist';
  import { getT, getLangCode } from '../i18n/client';

  const t    = getT();
  const tm   = t.media;
  const root = document.getElementById('media-root')!;

  // ── Parse URL param ──────────────────────────────────────────────────────
  const params  = new URLSearchParams(window.location.search);
  const rawId   = params.get('id') ?? '';
  const [type, numericStr] = rawId.split(':');
  const numericId = parseInt(numericStr ?? '', 10);

  if (!numericId || !['anime', 'manga', 'novel'].includes(type)) {
    root.innerHTML = renderError(tm.not_found);
  } else {
    root.innerHTML = renderLoading();
    fetchAniListDetail(numericId).then(media => {
      if (!media) { root.innerHTML = renderError(tm.not_found); return; }
      root.innerHTML = buildMediaHtml(media, type);
      initInteractions();
    });
  }

  // ── Loading / Error ───────────────────────────────────────────────────────
  function renderLoading(): string {
    return `<div class="media-loading"><div class="spinner"></div></div>`;
  }

  function renderError(msg: string): string {
    return `<div class="media-error"><span>${msg}</span></div>`;
  }

  // ── Status CSS class (no i18n — valores de API) ───────────────────────────
  const STATUS_CLASS: Record<string, string> = {
    RELEASING:        'media-badge--status-airing',
    NOT_YET_RELEASED: 'media-badge--status-upcoming',
  };

  type NullableDate = { year: number | null; month: number | null; day: number | null } | null;
  function fmtDate(d: NullableDate): string {
    if (!d?.year) return '';
    if (!d.month) return String(d.year);
    const date = new Date(d.year, d.month - 1, d.day ?? 1);
    return date.toLocaleDateString(getLangCode(), { year: 'numeric', month: 'short', day: d.day ? 'numeric' : undefined });
  }

  // ── Main render ───────────────────────────────────────────────────────────

  function buildMediaHtml(media: AniListMediaDetail, mediaType: string): string {
    const titleMain   = media.title.romaji ?? media.title.english ?? media.title.native ?? '—';
    const titleNative = media.title.native && media.title.native !== titleMain ? media.title.native : '';
    const titleEng    = media.title.english && media.title.english !== titleMain ? media.title.english : '';

    const coverSrc  = media.coverImage?.extraLarge ?? media.coverImage?.large ?? '';
    const coverColor = media.coverImage?.color ?? '#1a1a2e';

    // Banner
    const bannerHtml = media.bannerImage
      ? `<img class="media-banner-img" src="${media.bannerImage}" alt="" loading="lazy">`
      : '';
    const bannerClass = media.bannerImage ? 'media-banner' : 'media-banner media-banner--color';
    const bannerStyle = media.bannerImage ? '' : `style="--banner-color: linear-gradient(135deg, ${coverColor}22, ${coverColor}44)"`;

    // Meta badges
    const formatLabel = (tm.formats as Record<string, string>)[media.format ?? ''] ?? media.format ?? '';
    const statusLabel = (tm.statuses as Record<string, string>)[media.status ?? ''] ?? media.status ?? '';
    const statusClass = STATUS_CLASS[media.status ?? ''] ?? '';

    const durationInfo = media.duration ? `${media.duration} min/ep` : '';

    const startDateFormatted = fmtDate(media.startDate);
    const endDateFormatted = fmtDate(media.endDate);
    let dateBadgeHtml = '';
    if (startDateFormatted) {
      dateBadgeHtml = startDateFormatted;
      if (endDateFormatted) {
        dateBadgeHtml += ` - ${endDateFormatted}`;
      }
    }

    const seasonInfo = (media.season && media.seasonYear)
      ? `${(tm.seasons as Record<string, string>)[media.season] ?? media.season} ${media.seasonYear}`
      : fmtDate(media.startDate);

    const studio = media.studios.nodes[0]?.name ?? '';
    const source = media.source ? (tm.sources as Record<string, string>)[media.source] ?? media.source : '';

    // Score
    const score = media.averageScore ? (media.averageScore / 10).toFixed(1) : null;

    const startDateStr = fmtDate(media.startDate);
    const endDateStr = fmtDate(media.endDate);

    // Stats column items
    const statItems: [string, string][] = [
      ...(formatLabel     ? [[tm.stat_format,   formatLabel]          as [string,string]] : []),
      ...(media.episodes  ? [[tm.stat_episodes, String(media.episodes)] as [string,string]] : []),
      ...(media.chapters  ? [[tm.stat_chapters, String(media.chapters)] as [string,string]] : []),
      ...(media.volumes   ? [[tm.stat_volumes,  String(media.volumes)]  as [string,string]] : []),
      ...(durationInfo    ? [[tm.stat_duration, durationInfo]           as [string,string]] : []),
      ...(seasonInfo      ? [[tm.stat_season,   seasonInfo]             as [string,string]] : []),
      ...(startDateStr    ? [[tm.stat_start_date, startDateStr]         as [string,string]] : []),
      ...(endDateStr      ? [[tm.stat_end_date,   endDateStr]           as [string,string]] : []),
      ...(source          ? [[tm.stat_source,   source]                 as [string,string]] : []),
      ...(studio          ? [[tm.stat_studio,   studio]                 as [string,string]] : []),
      ...(score           ? [[tm.stat_score,    `★ ${score}`]           as [string,string]] : []),
    ];
    const statsHtml = statItems.map(([label, val]) => `
      <div class="media-stat-item">
        <span class="media-stat-label">${label}</span>
        <span class="media-stat-value">${val}</span>
      </div>`).join('');

    // Genres as dot-separated text
    const genreDots = media.genres.join(' · ');

    // Description
    const desc = media.description ?? '';

    // Characters
    const charCards = media.characters.nodes.map(c => `
      <div class="media-char-card">
        <img class="media-char-img" src="${c.image.medium ?? ''}" alt="${c.name.full}" loading="lazy">
        <span class="media-char-name">${c.name.full}</span>
      </div>
    `).join('');

    // Relations
    const validRelations = media.relations.edges.filter(e =>
      e.relationType !== 'CHARACTER' && e.node.coverImage?.medium,
    );

    const RELATION_PRIORITY: Record<string, number> = {
      PARENT: 1,      // Source / Original
      ADAPTATION: 2,  // Source / Adaptation
      PREQUEL: 3,     // Prequel
      SEQUEL: 4,      // Sequel
      SPIN_OFF: 5,    // Spin-off
      ALTERNATIVE: 6, // Alternative
      SUMMARY: 7,     // Summary
    };

    validRelations.sort((a, b) => {
      const prioA = RELATION_PRIORITY[a.relationType] ?? 99;
      const prioB = RELATION_PRIORITY[b.relationType] ?? 99;
      return prioA - prioB;
    });

    const relationCards = validRelations.map(e => {
      const relTitle = e.node.title.romaji ?? e.node.title.english ?? e.node.title.native ?? '';
      let relTypeLabel = (tm.relations as Record<string, string>)[e.relationType] ?? e.relationType;
      if (e.relationType === 'ADAPTATION' && mediaType === 'anime' && e.node.type === 'MANGA') {
        relTypeLabel = (tm.relations as Record<string, string>)['PARENT'] ?? 'Original';
      }
      const relCover = e.node.coverImage?.medium ?? e.node.coverImage?.large ?? '';
      const relPrefix = e.node.type?.toLowerCase() === 'anime' ? 'anime' : 'manga';
      const relUrl = `/media?id=${relPrefix}:${e.node.id}`;

      return `
        <a href="${relUrl}" class="media-relation-card group">
          <!-- Background cover blur -->
          <div class="media-relation-bg-layer">
            ${relCover ? `<img src="${relCover}" alt="" loading="lazy">` : ''}
          </div>
          <div class="media-relation-card-overlay"></div>
          
          <div class="media-relation-card-content">
            <!-- Floating thumbnail -->
            <div class="media-relation-thumb">
              ${relCover ? `<img src="${relCover}" alt="${relTitle}" loading="lazy">` : ''}
            </div>
            <!-- Info -->
            <div class="media-relation-info">
              <span class="media-relation-type">${relTypeLabel}</span>
              <span class="media-relation-title">${relTitle}</span>
            </div>
          </div>
        </a>
      `;
    }).join('');

    const PLUS_ICON = `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>`;
    const CHECK_ICON = `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;

    return `
      <!-- Hero -->
      <div class="media-hero">
        <div class="${bannerClass}" ${bannerStyle}>
          ${bannerHtml}
        </div>
        ${dateBadgeHtml ? `<div class="media-banner-date-badge">${dateBadgeHtml}</div>` : ''}

        <div class="media-hero-body">
          <!-- Izquierda: títulos -->
          <div class="media-hero-left">
            <h1 class="media-title-main">${titleMain}</h1>
            ${titleNative ? `<p class="media-title-native">${titleNative}</p>` : ''}
            ${titleEng    ? `<p class="media-title-english">${titleEng}</p>`  : ''}
          </div>

          <!-- Centro: cover -->
          <div class="media-cover-wrap" id="media-add-btn"
               data-external-id="${mediaType}:${media.id}" data-type="${mediaType}"
               role="button" tabindex="0" aria-label="${tm.add_to_library.replace('\n', ' ')}">
            ${coverSrc ? `<img class="media-cover-img" src="${coverSrc}" alt="${titleMain}">` : ''}
            <div class="media-cover-overlay">
              <div class="media-cover-overlay-inner">
                <span class="media-cover-overlay-icon">${PLUS_ICON}</span>
                <span class="media-cover-overlay-label">${tm.add_to_library.replace('\n', '<br>')}</span>
              </div>
            </div>
          </div>

          <!-- Derecha: géneros + estado -->
          <div class="media-hero-right">
            ${statusLabel ? `<span class="media-badge ${statusClass}">${statusLabel}</span>` : ''}
            ${genreDots   ? `<p class="media-genres-dots">${genreDots}</p>` : ''}
          </div>
        </div>
      </div>

      <!-- Body: 3 columns -->
      <div class="media-body">

        <!-- Col 1: Synopsis -->
        <div class="media-col-synopsis">
          ${desc ? `
            <p class="section-label">${tm.section_synopsis}</p>
            <div class="media-description-text">${desc}</div>
          ` : ''}
        </div>

        <!-- Col 2: Related -->
        <div class="media-col-related">
          ${relationCards ? `
            <p class="section-label">${tm.section_related}</p>
            <div class="media-relations-grid">${relationCards}</div>
          ` : ''}
        </div>

        <!-- Col 3: Stats -->
        <div class="media-col-stats">
          <p class="section-label">${tm.section_data}</p>
          <div class="media-stats-list">${statsHtml}</div>
        </div>

      </div>

      <!-- Characters (full-width) -->
      ${charCards ? `
        <div class="media-chars-section">
          <p class="section-label">${tm.section_characters}</p>
          <div class="media-chars-grid">${charCards}</div>
        </div>
      ` : ''}
    `;
  }

  // ── Interactions ─────────────────────────────────────────────────────────
  function initInteractions() {
    // Cover = add-to-library trigger
    const coverWrap = document.getElementById('media-add-btn');
    if (coverWrap) {
      const overlay      = coverWrap.querySelector<HTMLElement>('.media-cover-overlay');
      const overlayIcon  = coverWrap.querySelector<HTMLElement>('.media-cover-overlay-icon');
      const overlayLabel = coverWrap.querySelector<HTMLElement>('.media-cover-overlay-label');

      function setInLibrary(inLib: boolean) {
        coverWrap.classList.toggle('in-library', inLib);
        if (overlayIcon)  overlayIcon.innerHTML  = inLib
          ? `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`
          : `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>`;
        if (overlayLabel) overlayLabel.innerHTML = (inLib ? tm.in_library : tm.add_to_library).replace('\n', '<br>');
      }

      coverWrap.addEventListener('click', () => {
        // TODO: conectar con flujo de biblioteca real
        const next = !coverWrap.classList.contains('in-library');
        setInLibrary(next);
      });
      coverWrap.addEventListener('keydown', (e: Event) => {
        const ke = e as KeyboardEvent;
        if (ke.key === 'Enter' || ke.key === ' ') { ke.preventDefault(); coverWrap.click(); }
      });
    }
  }
</script>
