---
import '../styles/search.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLang, useTranslations } from '../i18n/index';
import SearchIsland from '../components/search/SearchIsland';

const lang = getLang(Astro.url);
const t    = useTranslations(lang);

const q    = Astro.url.searchParams.get('q') ?? '';
const type = (Astro.url.searchParams.get('type') ?? 'anime') as any;
---

<BaseLayout title={`${t.search.title} — Metadea`} lang={lang} activePage="search">
  <main>
    <SearchIsland client:load initialQ={q} initialType={type} />
  </main>
</BaseLayout>
