---
import '../styles/search.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLang, useTranslations } from '../i18n/index';
import SearchIsland from '../components/search/SearchIsland';

const lang = getLang(Astro.url);
const t    = useTranslations(lang);

import type { MediaType } from '../lib/search';

const VALID_MEDIA_TYPES: MediaType[] = ['all', 'anime', 'manga', 'novel', 'game', 'vnovel', 'movie', 'series', 'book', 'user'];

const q             = Astro.url.searchParams.get('q') ?? '';
const rawType       = Astro.url.searchParams.get('type') ?? 'all';
const type: MediaType = (VALID_MEDIA_TYPES as string[]).includes(rawType) ? rawType as MediaType : 'all';
---

<BaseLayout title={`${t.search.title} — Metadea`} lang={lang} activePage="search">
  <main>
    <SearchIsland
      client:load
      initialQuery={q}
      initialType={type}
      i18n={t.search}
    />
  </main>
</BaseLayout>
