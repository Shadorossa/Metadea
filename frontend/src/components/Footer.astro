---
interface Props {
  lang: 'es' | 'en';
}

const { lang } = Astro.props;

const apis = [
  { name: 'IGDB', logo: '/API/IGDB_logo.png', url: 'https://www.igdb.com' },
  { name: 'AniList', logo: '/API/Anilist_logo.png', url: 'https://anilist.co' },
  { name: 'Open Library', logo: '/API/Open_Library_tight_logo.png', url: 'https://openlibrary.org' },
  { name: 'TheMovieDB', logo: '/API/Tmdb.new.logo.png', url: 'https://www.themoviedb.org' },
  { name: 'AnimeTheme', logo: '/API/Animetheme_logo.png', url: 'https://animetheme.me' },
  { name: 'Wikidata', logo: '/API/Wikidata_logo.png', url: 'https://www.wikidata.org' },
];

const poweredByText = lang === 'es' ? 'Impulsado por' : 'Powered by';
---

<footer class="app-footer">
  <div class="footer-content">
    <div class="footer-text">{poweredByText}</div>
    <div class="footer-logos">
      {apis.map(api => (
        <a
          href={api.url}
          target="_blank"
          rel="noopener noreferrer"
          class="footer-logo-link"
          title={api.name}
          aria-label={`${api.name} - External link`}
        >
          <img src={api.logo} alt={api.name} class="footer-logo" />
        </a>
      ))}
    </div>
  </div>
</footer>
