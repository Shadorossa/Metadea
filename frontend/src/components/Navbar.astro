---
import type { Translations } from '../i18n/index';

interface Props {
  activePage?: 'home' | 'search' | 'local' | 'notifications' | 'profile' | 'tier';
  i18n: Translations['nav'];
}
const { activePage, i18n } = Astro.props;
---

<header class="navbar">
  <!-- Izquierda: home + search -->
  <div class="nav-group">
    <a href="/home"   class={`nav-icon-btn${activePage === 'home'   ? ' active' : ''}`} title={i18n.home}>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 9.5L12 3l9 6.5V20a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V9.5z"/>
        <polyline points="9 21 9 12 15 12 15 21"/>
      </svg>
    </a>
    <a href="/search" class={`nav-icon-btn${activePage === 'search' ? ' active' : ''}`} title={i18n.search}>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="7"/>
        <line x1="16.5" y1="16.5" x2="22" y2="22"/>
      </svg>
    </a>
    <a href="/tier" class={`nav-icon-btn nav-icon-btn--tier${activePage === 'tier' ? ' active' : ''}`} title="Tier list">
      <span class="nav-tier-s">S</span>
    </a>
    <a href="/local" class={`nav-icon-btn${activePage === 'local' ? ' active' : ''}`} title="Biblioteca local">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="2" y="3" width="20" height="14" rx="2"/>
        <line x1="8" y1="21" x2="16" y2="21"/>
        <line x1="12" y1="17" x2="12" y2="21"/>
      </svg>
    </a>
  </div>

  <!-- Centro: slot para contenido de página (ej. tabs de local) -->
  <div id="nav-center-slot" class="nav-center-slot"></div>

  <!-- Derecha: notificaciones + usuario -->
  <div class="nav-group">
    <a href="/notifications" class={`nav-icon-btn${activePage === 'notifications' ? ' active' : ''}`} title={i18n.notifications}>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
        <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
      </svg>
    </a>
    <div class="nav-user-wrap" id="nav-user-wrap">
      <button id="open-auth-modal" class={`nav-icon-btn${activePage === 'profile' ? ' active' : ''}`} title={i18n.account}>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="8" r="4"/>
          <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
        </svg>
      </button>
      <div class="nav-user-dropdown" id="nav-user-dropdown">
        <div class="nav-user-dropdown-inner">
          <a href="/profile" class="nav-dropdown-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
            Perfil
          </a>
          <a href="/settings" class="nav-dropdown-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
            Configuración
          </a>
          <div class="nav-dropdown-divider"></div>
          <button class="nav-dropdown-item nav-dropdown-item--danger" id="nav-signout-btn">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            Cerrar sesión
          </button>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  function initNavbar() {
    const dropdown  = document.getElementById('nav-user-dropdown');
    const authBtn   = document.getElementById('open-auth-modal');
    const signoutBtn = document.getElementById('nav-signout-btn');

    authBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      dropdown?.classList.toggle('is-open');
    });

    // Use AbortController so the document listener is removed before the next swap
    const ac = new AbortController();
    document.addEventListener('click', () => {
      dropdown?.classList.remove('is-open');
    }, { signal: ac.signal });
    document.addEventListener('astro:before-swap', () => ac.abort(), { once: true });

    signoutBtn?.addEventListener('click', async () => {
      try {
        const { clearAuthToken } = await import(/* @vite-ignore */ '../lib/tauri');
        await clearAuthToken();
      } catch {
        localStorage.removeItem('auth_token');
        localStorage.removeItem('auth_username');
      }
      window.location.href = '/';
    });
  }

  // astro:page-load fires on initial load AND after every View Transitions navigation
  document.addEventListener('astro:page-load', initNavbar);
</script>

<style>
  .nav-user-dropdown.is-open {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }
</style>
