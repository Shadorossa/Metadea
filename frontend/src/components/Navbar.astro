---
import type { Translations } from '../i18n/index';

interface Props {
  activePage?: 'home' | 'search' | 'local' | 'notifications' | 'profile' | 'tier';
  i18n: Translations['nav'];
}
const { activePage, i18n } = Astro.props;
---

<header class={`navbar${activePage === 'search' ? ' navbar--transparent' : ''}`}>
  <!-- Izquierda: home + search -->
  <div class="nav-group">
    <a href="/home"   data-nav="home"   class={`nav-icon-btn${activePage === 'home'   ? ' active' : ''}`} title={i18n.home}>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 9.5L12 3l9 6.5V20a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V9.5z"/>
        <polyline points="9 21 9 12 15 12 15 21"/>
      </svg>
    </a>
    <a href="/search" data-nav="search" class={`nav-icon-btn${activePage === 'search' ? ' active' : ''}`} title={i18n.search}>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="7"/>
        <line x1="16.5" y1="16.5" x2="22" y2="22"/>
      </svg>
    </a>
    <a href="/tier" data-nav="tier" class={`nav-icon-btn nav-icon-btn--tier${activePage === 'tier' ? ' active' : ''}`} title="Tier list">
      <span class="nav-tier-s">S</span>
    </a>
    <a href="/local" data-nav="local" class={`nav-icon-btn${activePage === 'local' ? ' active' : ''}`} title="Biblioteca local">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="2" y="3" width="20" height="14" rx="2"/>
        <line x1="8" y1="21" x2="16" y2="21"/>
        <line x1="12" y1="17" x2="12" y2="21"/>
      </svg>
    </a>
  </div>

  <!-- Centro: slot para contenido de página (ej. tabs de local) -->
  <div id="nav-center-slot" class="nav-center-slot"></div>

  <!-- Derecha: notificaciones + usuario -->
  <div class="nav-group">
    <a href="/notifications" data-nav="notifications" class={`nav-icon-btn${activePage === 'notifications' ? ' active' : ''}`} title={i18n.notifications}>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
        <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
      </svg>
    </a>
    <a
      href={activePage === 'profile' ? '/settings' : '/profile'}
      id="nav-account-btn"
      data-nav="account"
      class={`nav-icon-btn${activePage === 'profile' ? ' active is-settings-mode' : ''}`}
      title={i18n.account}
    >
      <svg class="nav-icon-account-profile" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="8" r="4"/>
        <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
      </svg>
      <svg class="nav-icon-account-settings" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
      </svg>
    </a>
  </div>
</header>

<script>
  // Routes that map to each nav icon — mirrors the activePage prop each page
  // passes to BaseLayout. Needed because the navbar is transition:persist'd
  // (it never unmounts/remounts across View Transitions navigations, which is
  // what stops it from flickering), so the server-rendered activePage classes
  // go stale after the first navigation — this recomputes them client-side.
  function computeActivePage(pathname: string): string | undefined {
    if (pathname.startsWith('/home')) return 'home';
    if (pathname.startsWith('/character')) return 'search';
    if (pathname.startsWith('/search')) return 'search';
    if (pathname.startsWith('/tier')) return 'tier';
    if (pathname.startsWith('/notifications')) return 'notifications';
    if (pathname.startsWith('/local')) return 'local';
    if (pathname.startsWith('/profile') || pathname.startsWith('/settings')) return 'account';
    return undefined;
  }

  function updateActiveNav() {
    const path = window.location.pathname;
    const key = computeActivePage(path);
    document.querySelectorAll('.navbar [data-nav]').forEach(el => {
      el.classList.toggle('active', el.getAttribute('data-nav') === key);
    });
    document.querySelector('.navbar')?.classList.toggle('navbar--transparent', key === 'search');

    // The account icon doubles as a profile/settings toggle: on /profile it
    // shows the settings icon (and links there); everywhere else — including
    // /settings itself — it shows the profile icon (and links to /profile).
    const accountBtn = document.getElementById('nav-account-btn') as HTMLAnchorElement | null;
    if (accountBtn) {
      const onProfile = path.startsWith('/profile');
      accountBtn.href = onProfile ? '/settings' : '/profile';
      accountBtn.classList.toggle('is-settings-mode', onProfile);
    }
  }

  // astro:page-load fires on initial load AND after every View Transitions
  // navigation — that's all this persisted navbar needs now that the account
  // button is a plain link instead of a dropdown.
  document.addEventListener('astro:page-load', updateActiveNav);
</script>
