---
import {
  ICON_UPLOAD_IMAGE,
  ICON_CHEVRON_LEFT,
  ICON_CHEVRON_RIGHT,
  ICON_RESET_ARROW,
  ICON_TRASH,
} from "../../lib/shared/icon-strings";
import type { Translations } from "../../i18n/index";

interface Props {
  t: Translations;
}
const { t } = Astro.props;
---

<!-- Tab: Apariencia (Perfil) -->
<div class="settings-panel" id="panel-profile">
  <h2 class="settings-panel-title" data-i18n="settings.section_appearance">{t.settings.section_appearance}</h2>

  <!-- Avatar + Banner en la misma fila -->
  <div class="profile-media-row">
    <!-- Nombre en la app + Fuente del nombre, fusionados: el input del
         nombre ES el preview de la fuente, en vez de dos controles que
         mostraban/editaban el mismo nombre por separado. -->
    <div class="settings-section settings-section--display-name">
      <h3 class="settings-section-title" data-i18n="settings.display_name_title">{t.settings.display_name_title}</h3>
      <div class="font-picker">
        <input
          type="text"
          id="display-name-input"
          class="font-preview-input"
          data-i18n="settings.display_name_placeholder"
          placeholder={t.settings.display_name_placeholder}
          maxlength="40"
          autocomplete="off"
          spellcheck="false"
        />
        <h3 class="settings-section-title font-picker-title" data-i18n="settings.font_title">{t.settings.font_title}</h3>
        <div class="font-picker-controls">
          <button
            class="font-arrow"
            id="font-prev"
            data-i18n-title="settings.font_prev"
            aria-label={t.settings.font_prev}
            set:html={ICON_CHEVRON_LEFT}
          />
          <span class="font-name-label" id="font-name-label"></span>
          <button
            class="font-arrow"
            id="font-next"
            data-i18n-title="settings.font_next"
            aria-label={t.settings.font_next}
            set:html={ICON_CHEVRON_RIGHT}
          />
        </div>
      </div>
    </div>

    <!-- Avatar -->
    <div class="settings-section settings-section--avatar">
      <h3 class="settings-section-title" data-i18n="settings.avatar_title">{t.settings.avatar_title}</h3>
      <div class="avatar-preview-wrap" id="avatar-preview">
        <!-- populated by script -->
      </div>
      <div class="avatar-upload-btns">
        <button
          class="btn btn--sm btn--secondary btn--icon-only"
          id="avatar-upload-btn"
          data-i18n-title="settings.avatar_upload"
          title={t.settings.avatar_upload}
          aria-label={t.settings.avatar_upload}
          set:html={ICON_UPLOAD_IMAGE}
        ></button>
        <button
          class="btn btn--sm btn--ghost btn--icon-only"
          id="avatar-remove-btn"
          data-i18n-title="settings.avatar_remove"
          title={t.settings.avatar_remove}
          aria-label={t.settings.avatar_remove}
          set:html={ICON_TRASH}
        ></button>
      </div>
      <input type="file" id="avatar-input" accept="image/*" hidden />
    </div>

    <!-- Banner -->
    <div class="settings-section settings-section--banner">
      <h3 class="settings-section-title" data-i18n="settings.banner_title">{t.settings.banner_title}</h3>
      <div class="banner-drop-zone" id="banner-drop-zone">
        <div class="banner-drop-hint">
          <Fragment set:html={ICON_UPLOAD_IMAGE} />
          <span data-i18n="settings.banner_drag">{t.settings.banner_drag}</span>
        </div>
      </div>
      <div class="banner-actions">
        <button class="btn btn--sm btn--secondary" id="banner-upload-btn" data-i18n="settings.banner_upload"
          >{t.settings.banner_upload}</button
        >
        <button class="btn btn--sm btn--ghost" id="banner-remove-btn" data-i18n="settings.banner_remove"
          >{t.settings.banner_remove}</button
        >
      </div>
      <input type="file" id="banner-input" accept="image/*" hidden />
    </div>
  </div>

  <!-- Biografía, Color Personalizado y Fondo Dinámico lado a lado -->
  <div class="settings-divider settings-divider--row settings-divider--wrap">
    <!-- Biografía -->
    <div class="settings-section flex-1">
      <h3 class="settings-section-title" data-i18n="settings.bio_title">{t.settings.bio_title}</h3>
      <textarea
        id="bio-textarea"
        class="settings-textarea"
        data-i18n="settings.bio_placeholder"
        placeholder={t.settings.bio_placeholder}
        maxlength="500"
        rows="5"
      >
      </textarea>
      <div class="settings-bio-count">
        <span id="bio-char-count">0</span>/500
      </div>
    </div>

    <!-- Color Personalizado -->
    <div class="settings-section settings-section--color">
      <h3 class="settings-section-title" data-i18n="settings.custom_color_title">
        {t.settings.custom_color_title}
      </h3>
      <div class="color-picker-container">
        <input
          type="color"
          id="custom-color-input"
          class="color-input"
          value="#c084fc"
        />
        <button
          class="btn btn--sm btn--ghost color-reset-btn"
          id="color-reset-btn"
          data-i18n-title="settings.color_reset_title"
          title={t.settings.color_reset_title}
          aria-label={t.settings.color_reset_title}
          set:html={ICON_RESET_ARROW}
        ></button>
      </div>
    </div>

    <!-- Selector de Fondo Dinámico -->
    <div class="settings-section settings-section--theme">
      <h3 class="settings-section-title" data-i18n="settings.appearance_bg_title">
        {t.settings.appearance_bg_title}
      </h3>
      <p class="settings-hint" data-i18n="settings.appearance_bg_hint">{t.settings.appearance_bg_hint}</p>
      <div class="theme-grid" id="theme-grid"></div>
    </div>
  </div>

  <!-- Cerrar sesión -->
  <div class="settings-divider">
    <button
      class="btn btn--sm btn--secondary settings-signout-btn"
      id="settings-signout-btn"
    >
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline
          points="16 17 21 12 16 7"></polyline><line
          x1="21"
          y1="12"
          x2="9"
          y2="12"></line></svg
      >
      <span data-i18n="profile.sign_out">{t.profile.sign_out}</span>
    </button>
  </div>
</div>
