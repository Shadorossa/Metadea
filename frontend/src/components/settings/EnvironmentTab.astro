---
import { ICON_HELP_CIRCLE } from "../../lib/shared/icon-strings";
import type { Translations } from "../../i18n/index";

interface Props {
  t: Translations;
}
const { t } = Astro.props;
---

<!-- Tab: Entorno -->
<div class="settings-panel hidden" id="panel-environment">
  <h2 class="settings-panel-title">{t.settings.tab_environment}</h2>

  <div class="settings-section">
    <h3 class="settings-section-title">{t.settings.env_title}</h3>

    <!-- API Platforms Selector Bar -->
    <div class="api-platforms-selector">
      <div class="api-platform-item">
        <button type="button" class="api-platform-tab-btn" data-platform="igdb" title={t.settings.env_platform_igdb_title}>
          <img class="api-platform-logo" src="/API/IGDB_logo.png" alt="IGDB" />
        </button>
        <span class="api-platform-label">Videojuegos</span>
      </div>
      <div class="api-platform-item">
        <button type="button" class="api-platform-tab-btn" data-platform="tmdb" title={t.settings.env_platform_tmdb_title}>
          <img class="api-platform-logo" src="/API/Tmdb.new.logo.png" alt="TMDB" />
        </button>
        <span class="api-platform-label">Cine y series</span>
      </div>
      <div class="api-platform-item">
        <button type="button" class="api-platform-tab-btn" data-platform="steam" title={t.settings.env_platform_steam_title}>
          <img class="api-platform-logo" src="/platforms/steam_logo.png" alt="Steam" />
        </button>
        <span class="api-platform-label">Steam</span>
      </div>
      <div class="api-platform-item">
        <button type="button" class="api-platform-tab-btn" data-platform="anilist" title={t.settings.env_platform_anilist_title}>
          <img class="api-platform-logo" src="/API/Anilist_logo.png" alt="AniList" />
        </button>
        <span class="api-platform-label">Anime y manga</span>
      </div>
      <div class="api-platform-item">
        <button type="button" class="api-platform-tab-btn" data-platform="comicvine" title={t.settings.env_platform_comicvine_title}>
          <svg class="api-platform-logo" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 3h13l3 3v15H4z"/>
            <path d="M17 3v3h3"/>
            <line x1="7" y1="9" x2="15" y2="9"/>
            <line x1="7" y1="13" x2="15" y2="13"/>
            <line x1="7" y1="17" x2="12" y2="17"/>
          </svg>
        </button>
        <span class="api-platform-label">{t.settings.env_platform_comics_label}</span>
      </div>
    </div>

    <!-- API Keys Safe Content Viewport -->
    <div class="api-keys-viewport">

      <!-- State: None selected (Default) -->
      <div class="api-keys-empty-placeholder" id="api-keys-placeholder">
        <span class="api-keys-placeholder-icon">🔑</span>
        <h4>{t.settings.env_platform_empty_title}</h4>
        <p>{t.settings.env_platform_empty_hint}</p>
      </div>

      <!-- Form: IGDB -->
      <div class="api-platform-form-block hidden" id="api-form-igdb">
        <div class="env-service-header" style="position: relative; margin-bottom: 1.25rem;">
          <span class="api-form-service-title">Twitch / IGDB API</span>
          <button type="button" class="settings-help-btn" data-help="igdb" title={t.settings.env_igdb_help_title} style="position: absolute; top: 0; right: 0;">
            <Fragment set:html={ICON_HELP_CIRCLE} />
          </button>
        </div>
        <div class="env-fields env-fields--row">
          <div class="env-field">
            <label class="env-label" for="igdb-client-id">{t.settings.env_igdb_client_id}</label>
            <input
              class="env-input"
              type="text"
              id="igdb-client-id"
              placeholder="xxxxxxxxxxxxxxxxxxxxxxxx"
              autocomplete="off"
              spellcheck="false"
            />
          </div>
          <div class="env-field">
            <label class="env-label" for="igdb-client-secret">{t.settings.env_igdb_client_secret}</label>
            <input
              class="env-input"
              type="password"
              id="igdb-client-secret"
              placeholder="••••••••••••••••••••••••"
              autocomplete="off"
            />
          </div>
        </div>
      </div>

      <!-- Form: TMDB -->
      <div class="api-platform-form-block hidden" id="api-form-tmdb">
        <div class="env-service-header" style="position: relative; margin-bottom: 1.25rem;">
          <span class="api-form-service-title">TheMovieDB API</span>
          <button type="button" class="settings-help-btn" data-help="tmdb" title={t.settings.env_tmdb_help_title} style="position: absolute; top: 0; right: 0;">
            <Fragment set:html={ICON_HELP_CIRCLE} />
          </button>
        </div>
        <div class="env-fields env-fields--row">
          <div class="env-field">
            <label class="env-label" for="tmdb-access-token">{t.settings.env_tmdb_access_token}</label>
            <input
              class="env-input"
              type="password"
              id="tmdb-access-token"
              placeholder="••••••••••••••••••••••••••••••••"
              autocomplete="off"
            />
          </div>
          <div class="env-field">
            <label class="env-label" for="tmdb-api-key">{t.settings.env_tmdb_api_key}</label>
            <input
              class="env-input"
              type="password"
              id="tmdb-api-key"
              placeholder="••••••••••••••••••••••••••••••••"
              autocomplete="off"
            />
          </div>
        </div>
      </div>

      <!-- Form: Steam -->
      <div class="api-platform-form-block hidden" id="api-form-steam">
        <div class="env-service-header" style="position: relative; margin-bottom: 1.25rem;">
          <span class="api-form-service-title">Steam Web API</span>
          <button type="button" class="settings-help-btn" data-help="steam" title={t.settings.env_steam_help_title} style="position: absolute; top: 0; right: 0;">
            <Fragment set:html={ICON_HELP_CIRCLE} />
          </button>
        </div>
        <div class="env-fields">
          <div class="env-field">
            <label class="env-label" for="steam-api-key">{t.settings.env_steam_api_key}</label>
            <input
              class="env-input"
              type="password"
              id="steam-api-key"
              placeholder="••••••••••••••••••••••••••••••••"
              autocomplete="off"
            />
          </div>
        </div>
      </div>

      <!-- Form: AniList -->
      <div class="api-platform-form-block hidden" id="api-form-anilist">
        <div class="env-service-header" style="position: relative; margin-bottom: 1.25rem;">
          <span class="api-form-service-title">AniList Developer API</span>
          <button type="button" class="settings-help-btn" data-help="anilist" title={t.settings.env_anilist_help_title} style="position: absolute; top: 0; right: 0;">
            <Fragment set:html={ICON_HELP_CIRCLE} />
          </button>
        </div>
        <div class="env-fields">
          <div class="env-field">
            <label class="env-label" for="anilist-client-id">Client ID</label>
            <input
              class="env-input"
              type="text"
              id="anilist-client-id"
              placeholder={t.settings.env_anilist_client_id_ph}
              autocomplete="off"
            />
          </div>
        </div>
      </div>

      <!-- Form: Comic Vine -->
      <div class="api-platform-form-block hidden" id="api-form-comicvine">
        <div class="env-service-header" style="position: relative; margin-bottom: 1.25rem;">
          <span class="api-form-service-title">Comic Vine API</span>
          <button type="button" class="settings-help-btn" data-help="comicvine" title={t.settings.env_comicvine_help_title} style="position: absolute; top: 0; right: 0;">
            <Fragment set:html={ICON_HELP_CIRCLE} />
          </button>
        </div>
        <div class="env-fields">
          <div class="env-field">
            <label class="env-label" for="comicvine-api-key">API Key</label>
            <input
              class="env-input"
              type="password"
              id="comicvine-api-key"
              placeholder="••••••••••••••••••••••••••••••••"
              autocomplete="off"
            />
          </div>
        </div>
      </div>

    </div>

    <div class="settings-divider settings-divider--actions" style="justify-content: center; margin-top: 1.5rem;">
      <button class="btn btn--primary" id="env-save-btn"
        >{t.settings.env_save}</button
      >
      <button class="btn btn--ghost" id="env-clear-btn"
        >{t.settings.env_clear}</button
      >
    </div>
  </div>

  <!-- Local Routes -->
  <div class="settings-section" style="margin-top: 2rem;">
    <h3 class="settings-section-title">{t.settings.local_routes_title}</h3>
    <p class="settings-hint">{t.settings.local_routes_hint}</p>
    <div id="local-routes-list" style="display: flex; flex-direction: column; gap: 0.75rem; margin-top: 0.75rem;">
      <!-- Populated by JS -->
    </div>
    <button
      class="btn btn--sm btn--ghost"
      id="open-env-folder-btn"
      style="margin-top: 1rem;"
    >
      📁 {t.settings.env_open_folder}
    </button>
  </div>

  <!-- Catalog maintenance -->
  <div class="settings-section" style="margin-top: 2rem;">
    <h3 class="settings-section-title">{t.settings.catalog_health_title}</h3>
    <p class="settings-hint">{t.settings.catalog_health_hint}</p>
    <button class="btn btn--sm btn--ghost" id="catalog-health-btn" style="margin-top: 0.75rem;">
      🔍 {t.settings.catalog_health_btn}
    </button>
    <div
      id="catalog-health-results"
      class="settings-modal"
      style="margin-top: 1rem; align-items: stretch; text-align: left; max-height: 320px; overflow-y: auto;"
    ></div>
  </div>

</div>
