---
// Every "¿Qué es X?" / "¿Cómo obtener la clave de X?" popup in Settings,
// in one shared place instead of split across ConnectionsTab.astro and
// EnvironmentTab.astro. That split used to cause two real bugs:
//   1. Both tabs had their own <div id="anilist-help-modal">, a duplicate
//      DOM id — document.getElementById always resolves to whichever one
//      rendered first (EnvironmentTab's, since it's imported before
//      ConnectionsTab in settings.astro), so Conexiones' AniList "i" button
//      always opened *Environment*'s modal instead of its own.
//   2. Every modal lived nested inside its own tab's .settings-panel, which
//      gets display:none whenever that tab isn't the active one — so
//      opening a help modal while on a *different* tab (exactly what the
//      duplicate-id bug above forced) rendered it invisible, hidden along
//      with the whole panel it happened to be sitting in.
// Rendered once in settings.astro, as a sibling of .settings-content (not
// nested inside any single .settings-panel), so every help button works
// identically regardless of which tab is currently active — see
// setupHelpModals() in settings.astro, which is itself already generic
// (data-help="x" opens #x-help-modal) and needed no changes for this.

import type { Translations } from '../../i18n/index';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<!-- GitHub -->
<div id="github-help-modal" class="settings-help-modal hidden">
  <div class="settings-help-modal-overlay"></div>
  <div class="settings-help-modal-content">
    <div class="settings-help-modal-header">
      <h3>{t.help.github_title}</h3>
      <button class="settings-help-modal-close" data-modal="github-help-modal">&times;</button>
    </div>
    <div class="settings-help-modal-body">
      <p set:html={t.help.github_body1} />
      <p>{t.help.github_body2}</p>
      <ul style="margin: 1rem 0 0 1.5rem; list-style: disc;">
        <li set:html={t.help.github_item1} />
        <li set:html={t.help.github_item2} />
        <li set:html={t.help.github_item3} />
      </ul>
    </div>
  </div>
</div>

<!-- AniList — merged: what it's used for (Conexiones' own entry point)
     plus how to get the developer key (Entorno's own entry point), since
     both buttons only ever get to share one modal anyway. -->
<div id="anilist-help-modal" class="settings-help-modal hidden">
  <div class="settings-help-modal-overlay"></div>
  <div class="settings-help-modal-content">
    <div class="settings-help-modal-header">
      <h3>{t.help.anilist_title}</h3>
      <button class="settings-help-modal-close" data-modal="anilist-help-modal">&times;</button>
    </div>
    <div class="settings-help-modal-body">
      <p set:html={t.help.anilist_body1} />
      <ul style="margin: 1rem 0 0 1.5rem; list-style: disc;">
        <li set:html={t.help.anilist_item1} />
        <li set:html={t.help.anilist_item2} />
        <li set:html={t.help.anilist_item3} />
      </ul>
      <p style="margin-top: 1rem;" set:html={t.help.anilist_body2} />
      <ol style="margin: 1rem 0 0 1.5rem; list-style: decimal;">
        <li set:html={t.help.anilist_step1} />
        <li set:html={t.help.anilist_step2} />
        <li set:html={t.help.anilist_step3} />
        <li set:html={t.help.anilist_step4} />
        <li set:html={t.help.anilist_step5} />
        <li set:html={t.help.anilist_step6} />
      </ol>
      <p style="margin-top: 1rem; font-size: 0.9em; color: var(--text-muted);" set:html={t.help.anilist_body3} />
    </div>
  </div>
</div>

<!-- IGDB -->
<div id="igdb-help-modal" class="settings-help-modal hidden">
  <div class="settings-help-modal-overlay"></div>
  <div class="settings-help-modal-content">
    <div class="settings-help-modal-header">
      <h3>{t.help.igdb_title}</h3>
      <button class="settings-help-modal-close" data-modal="igdb-help-modal">&times;</button>
    </div>
    <div class="settings-help-modal-body">
      <p set:html={t.help.igdb_body1} />
      <p style="margin-top: 0.75rem; padding: 0.6rem 0.75rem; border-left: 3px solid var(--color-error, #ff6b6b); background: color-mix(in srgb, var(--color-error, #ff6b6b) 10%, transparent); border-radius: 4px; font-size: 0.9em;" set:html={t.help.igdb_warning} />
      <ol style="margin: 1rem 0 0 1.5rem; list-style: decimal;">
        <li set:html={t.help.igdb_step1} />
        <li set:html={t.help.igdb_step2} />
        <li set:html={t.help.igdb_step3} />
        <li>
          {t.help.igdb_step4}
          <ul style="margin: 0.4rem 0 0 1.25rem; list-style: disc;">
            <li set:html={t.help.igdb_step4_item1} />
            <li set:html={t.help.igdb_step4_item2} />
            <li set:html={t.help.igdb_step4_item3} />
          </ul>
        </li>
        <li set:html={t.help.igdb_step5} />
        <li set:html={t.help.igdb_step6} />
        <li set:html={t.help.igdb_step7} />
      </ol>
      <p style="margin-top: 1rem; font-size: 0.9em; color: var(--text-muted);" set:html={t.help.igdb_body2} />
      <p style="margin-top: 0.5rem; font-size: 0.9em; color: var(--text-muted);" set:html={t.help.igdb_body3} />
    </div>
  </div>
</div>

