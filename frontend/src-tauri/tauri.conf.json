{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Metadea",
  "version": "0.3.21",
  "identifier": "com.metadea.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:4321",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Metadea",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' https: data: asset: http://asset.localhost https://asset.localhost; connect-src 'self' https: ipc: http://asset.localhost https://asset.localhost; script-src 'self'; style-src 'self' 'unsafe-inline';",
      "dangerousDisableAssetCspModification": ["style-src"],
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/metadata/**"]
      }
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/Shadorossa/Metadea/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJDOERFQTQ0MjJEQkM1NTEKUldSUnhkc2lST3FOdkZodVArMHdEQ2xadU5kRDY5YXpaN0RZSE1IdjlqbUVwdDRvY2R6RnpXVDIK"
    }
  }
}